<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="mobile-web-app-capable" content="yes">
<title>Pangkas</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0a0f;--s1:#0f0f1a;--s2:#141420;--s3:#1a1a2a;--b1:#1e1e30;
  --teal:#0ABFBC;--teal2:#08a0a0;--teal3:rgba(10,191,188,.15);
  --ivory:#F1F1F3;--ash:#52526e;--sage:#10B981;--ember:#EF4444;--gold:#F59E0B;
  --rad:12px;
}
html,body{height:100%;font-family:'Segoe UI',sans-serif;background:var(--bg);color:var(--ivory);overflow:hidden}
body{display:flex;flex-direction:column}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--b1);border-radius:4px}

/* ── LOGIN ── */
#login{position:fixed;inset:0;z-index:999;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem}
.login-logo{text-align:center}
.login-logo img{width:100px;height:100px;object-fit:contain;border-radius:50%;border:2px solid var(--teal);padding:8px;background:var(--s1)}
.login-logo .brand{font-size:1.3rem;font-weight:800;color:var(--teal);margin-top:.5rem;letter-spacing:.05em}
.login-logo .sub{font-size:.75rem;color:var(--ash);margin-top:.2rem}
.login-card{background:var(--s1);border:1px solid rgba(10,191,188,.2);border-radius:20px;padding:1.8rem;width:320px;text-align:center}
.login-card h3{font-size:1rem;margin-bottom:.3rem}
.login-card p{font-size:.75rem;color:var(--ash);margin-bottom:1.2rem}
.pin-display{display:flex;justify-content:center;gap:.5rem;margin-bottom:1rem}
.pin-dot{width:14px;height:14px;border-radius:50%;border:2px solid rgba(10,191,188,.4);background:transparent;transition:all .2s}
.pin-dot.filled{background:var(--teal);border-color:var(--teal);box-shadow:0 0 8px rgba(10,191,188,.5)}
.pin-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.5rem;max-width:220px;margin:0 auto}
.pin-btn{padding:.9rem;background:var(--s2);border:1px solid var(--b1);border-radius:10px;color:var(--ivory);font-size:1.1rem;font-weight:600;cursor:pointer;transition:all .18s}
.pin-btn:hover{background:var(--s3);border-color:rgba(10,191,188,.3)}
.pin-btn:active{transform:scale(.95);background:var(--teal3)}
.pin-btn.del{color:var(--ember)}
.login-err{color:var(--ember);font-size:.72rem;margin-top:.5rem;min-height:1em}

/* ── APP ── */
#app{display:none;flex-direction:column;height:100vh;height:100dvh}
.topbar{background:var(--s1);border-bottom:1px solid rgba(10,191,188,.15);padding:.6rem 1rem;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.topbar-left{display:flex;align-items:center;gap:.6rem}
.topbar-logo{font-size:.9rem;font-weight:800;color:var(--teal);letter-spacing:.04em}
.topbar-user{font-size:.7rem;color:var(--ash);background:var(--s2);border:1px solid var(--b1);padding:.2rem .55rem;border-radius:20px}
.topbar-right{display:flex;gap:.4rem}
.tbtn{background:none;border:1px solid var(--b1);border-radius:8px;color:var(--ash);padding:.3rem .6rem;font-size:.72rem;cursor:pointer;transition:all .18s}
.tbtn:hover{border-color:rgba(10,191,188,.35);color:var(--ivory)}

/* ── NAV ── */
nav{background:var(--s1);border-bottom:1px solid rgba(255,255,255,.05);display:flex;overflow-x:auto;scrollbar-width:none;flex-shrink:0}
nav::-webkit-scrollbar{display:none}
.ntab{padding:.6rem .8rem;border:none;background:none;color:var(--ash);font-size:.75rem;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .2s;display:flex;align-items:center;gap:.3rem}
.ntab:hover{color:var(--ivory)}
.ntab.on{color:var(--teal);border-bottom-color:var(--teal)}

/* ── PANELS ── */
.panels{flex:1;overflow:hidden}
.panel{display:none;height:100%;overflow-y:auto;padding:1rem}
.panel.on{display:block}

/* ── CARDS ── */
.card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--rad);padding:1rem;margin-bottom:.75rem}
.card-title{font-size:.72rem;font-weight:700;color:var(--ash);text-transform:uppercase;letter-spacing:.08em;margin-bottom:.65rem;display:flex;align-items:center;justify-content:space-between}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem}
.stat-card{background:var(--s2);border:1px solid var(--b1);border-radius:var(--rad);padding:.9rem;text-align:center}
.stat-val{font-size:1.6rem;font-weight:800;color:var(--teal);line-height:1}
.stat-lbl{font-size:.68rem;color:var(--ash);margin-top:.3rem}

/* ── BUTTONS ── */
.btn{padding:.6rem 1.1rem;border:none;border-radius:9px;font-size:.8rem;font-weight:600;cursor:pointer;transition:all .18s;font-family:inherit}
.btn-teal{background:var(--teal);color:#fff}.btn-teal:hover{background:var(--teal2);box-shadow:0 4px 16px rgba(10,191,188,.3)}
.btn-outline{background:none;border:1px solid var(--b1);color:var(--ash)}.btn-outline:hover{border-color:rgba(10,191,188,.35);color:var(--ivory)}
.btn-danger{background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:#fca5a5}.btn-danger:hover{background:rgba(239,68,68,.2)}
.btn-sm{padding:.35rem .7rem;font-size:.72rem}
.btn-full{width:100%}

/* ── FORM ── */
.field{margin-bottom:.75rem}
.field label{display:block;font-size:.72rem;color:var(--ash);margin-bottom:.3rem;font-weight:600}
.finp{width:100%;padding:.6rem .8rem;background:var(--s2);border:1px solid var(--b1);border-radius:8px;color:var(--ivory);font-size:.82rem;font-family:inherit;outline:none;transition:border-color .2s}
.finp:focus{border-color:rgba(10,191,188,.5);background:rgba(10,191,188,.04)}
select.finp{cursor:pointer}

/* ── TABLE ── */
.tbl{width:100%;border-collapse:collapse;font-size:.78rem}
.tbl th{color:var(--ash);font-weight:600;text-align:left;padding:.4rem .6rem;border-bottom:1px solid var(--b1);font-size:.67rem;text-transform:uppercase;letter-spacing:.06em}
.tbl td{padding:.5rem .6rem;border-bottom:1px solid rgba(255,255,255,.04)}
.tbl tr:hover td{background:rgba(255,255,255,.02)}
.badge{display:inline-block;padding:.12rem .45rem;border-radius:20px;font-size:.62rem;font-weight:600}
.badge-teal{background:rgba(10,191,188,.12);color:var(--teal);border:1px solid rgba(10,191,188,.25)}
.badge-gold{background:rgba(245,158,11,.12);color:var(--gold);border:1px solid rgba(245,158,11,.25)}
.badge-red{background:rgba(239,68,68,.12);color:#fca5a5;border:1px solid rgba(239,68,68,.25)}
.badge-gray{background:rgba(255,255,255,.06);color:var(--ash);border:1px solid rgba(255,255,255,.1)}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.7);display:none;align-items:center;justify-content:center;padding:1rem}
.modal-overlay.open{display:flex}
.modal{background:var(--s1);border:1px solid rgba(10,191,188,.2);border-radius:18px;padding:1.4rem;width:100%;max-width:420px;max-height:90vh;overflow-y:auto}
.modal h3{font-size:1rem;margin-bottom:1rem;display:flex;align-items:center;gap:.5rem}
.modal-footer{display:flex;gap:.5rem;margin-top:1rem;justify-content:flex-end}

/* ── KASIR ── */
.service-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:.5rem;margin-bottom:.75rem}
.svc-btn{padding:.7rem .5rem;background:var(--s2);border:1px solid var(--b1);border-radius:10px;cursor:pointer;text-align:center;transition:all .18s;position:relative}
.svc-btn:hover{border-color:rgba(10,191,188,.3);background:rgba(10,191,188,.05)}
.svc-btn.sel{background:rgba(10,191,188,.1);border-color:rgba(10,191,188,.5);box-shadow:0 0 12px rgba(10,191,188,.15)}
.svc-btn .svc-name{font-size:.78rem;font-weight:600;margin-bottom:.2rem}
.svc-btn .svc-price{font-size:.72rem;color:var(--teal)}
.svc-btn .svc-qty{position:absolute;top:4px;right:6px;background:var(--teal);color:#fff;font-size:.6rem;font-weight:800;border-radius:10px;padding:.05rem .35rem}
.cart-item{display:flex;align-items:center;justify-content:space-between;padding:.4rem .6rem;background:var(--s2);border:1px solid var(--b1);border-radius:8px;margin-bottom:.3rem;font-size:.78rem}
.cart-total{font-size:1.1rem;font-weight:800;color:var(--teal);text-align:right;padding:.5rem 0}

/* ── APPOINTMENT ── */
.appt-slot{display:flex;align-items:center;gap:.6rem;padding:.55rem .7rem;background:var(--s2);border:1px solid var(--b1);border-radius:10px;margin-bottom:.4rem;cursor:pointer;transition:all .18s}
.appt-slot:hover{border-color:rgba(10,191,188,.3)}
.appt-time{font-size:.72rem;color:var(--teal);font-weight:700;min-width:42px;font-family:'Courier New',monospace}
.appt-info{flex:1}
.appt-name{font-size:.8rem;font-weight:600}
.appt-detail{font-size:.66rem;color:var(--ash)}

/* ── LAPORAN ── */
.period-tabs{display:flex;gap:.3rem;margin-bottom:.75rem}
.ptab{padding:.35rem .75rem;border:1px solid var(--b1);border-radius:20px;background:none;color:var(--ash);font-size:.72rem;cursor:pointer;transition:all .18s}
.ptab.on{background:rgba(10,191,188,.1);border-color:rgba(10,191,188,.4);color:var(--teal)}

/* ── STRUK PRINT ── */
@media print{
  body *{display:none!important}
  #struk-print{display:block!important;position:fixed;inset:0;z-index:9999;background:#fff;color:#000;padding:1rem;font-family:'Courier New',monospace;font-size:11px}
  #struk-print *{display:block!important}
}
#struk-print{display:none}
.struk-line{border-top:1px dashed #999;margin:.4rem 0}

/* ── APPOINTMENT CALENDAR ── */
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
.cal-nav{background:none;border:1px solid var(--b1);border-radius:7px;color:var(--ash);padding:.3rem .7rem;cursor:pointer;font-size:.8rem}
.cal-nav:hover{border-color:rgba(10,191,188,.35);color:var(--ivory)}
.cal-days{display:grid;grid-template-columns:repeat(7,1fr);gap:.3rem;margin-bottom:.5rem}
.cal-day-lbl{text-align:center;font-size:.6rem;color:var(--ash);padding:.2rem}
.cal-day{text-align:center;padding:.5rem .2rem;border-radius:8px;cursor:pointer;font-size:.78rem;transition:all .18s;border:1px solid transparent}
.cal-day:hover{background:var(--s2)}
.cal-day.today{background:rgba(10,191,188,.12);border-color:rgba(10,191,188,.35);color:var(--teal);font-weight:700}
.cal-day.selected{background:var(--teal);color:#fff;font-weight:700}
.cal-day.has-appt::after{content:'•';display:block;font-size:.5rem;color:var(--teal);line-height:.5}
.cal-day.empty{cursor:default}

/* ── EMPTY STATE ── */
.empty-state{text-align:center;padding:2.5rem 1rem;color:var(--ash)}
.empty-state .ei{font-size:2.5rem;margin-bottom:.5rem}
.empty-state p{font-size:.8rem}

/* ── MEMBERSHIP ── */
.member-card{background:linear-gradient(135deg,rgba(10,191,188,.15),rgba(10,191,188,.05));border:1px solid rgba(10,191,188,.3);border-radius:14px;padding:1rem;position:relative;overflow:hidden}
.member-card::before{content:'';position:absolute;top:-20px;right:-20px;width:80px;height:80px;border-radius:50%;background:rgba(10,191,188,.1)}
.member-name{font-size:1rem;font-weight:800;margin-bottom:.2rem}
.member-visits{font-size:.72rem;color:var(--teal)}
.visit-dots{display:flex;gap:.3rem;flex-wrap:wrap;margin-top:.5rem}
.vdot{width:10px;height:10px;border-radius:50%;background:var(--b1);border:1px solid rgba(255,255,255,.1)}
.vdot.done{background:var(--teal);box-shadow:0 0 6px rgba(10,191,188,.4)}

.rp-val{font-size:clamp(.85rem,3vw,1.2rem)!important;word-break:break-all}

/* ── PAYMENT BUTTONS ── */
.disc-chip{display:inline-flex;align-items:center;padding:.28rem .55rem;border:1px solid rgba(255,255,255,.1);border-radius:16px;background:rgba(255,255,255,.03);cursor:pointer;font-size:.72rem;color:var(--ash);transition:all .15s;white-space:nowrap}
.disc-chip.on{background:rgba(10,191,188,.15);border-color:rgba(10,191,188,.5);color:var(--teal);font-weight:700}
.pay-btn{background:var(--s2);border:1px solid var(--b1);border-radius:12px;padding:.9rem .5rem;cursor:pointer;font-size:.78rem;font-weight:600;color:var(--ivory);transition:all .18s;text-align:center;font-family:inherit}
.pay-btn:hover{border-color:rgba(10,191,188,.3);background:rgba(10,191,188,.05)}
.pay-btn.pay-sel{background:rgba(10,191,188,.12);border-color:rgba(10,191,188,.5);box-shadow:0 0 14px rgba(10,191,188,.15)}

/* ── DEBT CARD ── */
.debt-card{background:var(--s2);border:1px solid rgba(239,68,68,.2);border-radius:12px;padding:.75rem;margin-bottom:.5rem;transition:all .2s}
.debt-card.paid{border-color:rgba(10,191,188,.2);opacity:.6}
.debt-name{font-size:.85rem;font-weight:700}
.debt-amount{font-size:1rem;font-weight:800;color:var(--ember)}
.debt-amount.paid{color:var(--sage)}
.debt-meta{font-size:.68rem;color:var(--ash);margin-top:.2rem}

/* ── ADMIN PIN SETUP ── */
.pin-user-row{display:flex;align-items:center;justify-content:space-between;padding:.5rem .6rem;background:var(--s2);border:1px solid var(--b1);border-radius:8px;margin-bottom:.3rem;font-size:.78rem}
</style>
</head>
<body>

<!-- STRUK PRINT -->
<div id="struk-print"></div>

<!-- ONBOARDING -->
<div id="onboarding" style="display:none;position:fixed;inset:0;z-index:1000;background:var(--bg);align-items:center;justify-content:center;flex-direction:column;gap:1.5rem"></div>

<!-- LOGIN -->
<div id="login">
  <div class="login-logo">
    <div style="width:80px;height:80px;margin:0 auto;background:var(--s1);border-radius:50%;border:2px solid var(--teal);display:flex;align-items:center;justify-content:center;font-size:2rem">💈</div>
    <div class="brand" id="loginBrand">PANGKAS</div>
    <div class="sub">Barbershop Management</div>
  </div>
  <div class="login-card">
    <h3 id="login-title">Masukkan PIN</h3>
    <p id="login-sub">Masukkan PIN 4 digit kamu</p>
    <div class="pin-display" id="pinDisplay">
      <div class="pin-dot" id="pd0"></div>
      <div class="pin-dot" id="pd1"></div>
      <div class="pin-dot" id="pd2"></div>
      <div class="pin-dot" id="pd3"></div>
    </div>
    <div class="pin-grid">
      <button class="pin-btn" onclick="pinKey('1')">1</button>
      <button class="pin-btn" onclick="pinKey('2')">2</button>
      <button class="pin-btn" onclick="pinKey('3')">3</button>
      <button class="pin-btn" onclick="pinKey('4')">4</button>
      <button class="pin-btn" onclick="pinKey('5')">5</button>
      <button class="pin-btn" onclick="pinKey('6')">6</button>
      <button class="pin-btn" onclick="pinKey('7')">7</button>
      <button class="pin-btn" onclick="pinKey('8')">8</button>
      <button class="pin-btn" onclick="pinKey('9')">9</button>
      <button class="pin-btn btn-outline" onclick="pinClear()">C</button>
      <button class="pin-btn" onclick="pinKey('0')">0</button>
      <button class="pin-btn del" onclick="pinDel()">⌫</button>
    </div>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-left">
      <div class="topbar-logo" id="topLogo">💈 PANGKAS</div>
      <div class="topbar-user" id="topUser">—</div>
    </div>
    <div class="topbar-right">
      <button class="tbtn" onclick="logout()">Keluar</button>
    </div>
  </div>
  <nav id="mainNav"></nav>
  <div class="panels" id="panels"></div>
</div>

<!-- MODAL CONTAINER -->
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal" id="modalBox"></div>
</div>

<!-- PRINT AREA -->
<script>
// ══════════════════════════════════════════════
// DATABASE (localStorage)
// ══════════════════════════════════════════════
const DB = {
  get(k){ try{return JSON.parse(localStorage.getItem('rb_'+k))||null}catch{return null} },
  set(k,v){ localStorage.setItem('rb_'+k,JSON.stringify(v)) },
  def(k,v){ if(!localStorage.getItem('rb_'+k)) DB.set(k,v) }
};

// ── SEED DEFAULT DATA ──
DB.def('users',[
  {id:'anang',name:'Anang',pin:'1234',role:'admin'},
]);
DB.def('services',[
  {id:'s1',name:'Potong Rambut',price:35000,active:true},
  {id:'s2',name:'Cukur Jenggot',price:20000,active:true},
  {id:'s3',name:'Cuci Rambut',price:15000,active:true},
  {id:'s4',name:'Potong + Cuci',price:45000,active:true},
  {id:'s5',name:'Warna Rambut',price:100000,active:true},
  {id:'s6',name:'Hair Tonic',price:25000,active:true},
]);
DB.def('transactions',[]);
DB.def('appointments',[]);
DB.def('members',[]);
DB.def('settings',{commission:40,memberVisits:10,memberReward:'1x Potong Gratis',shopName:'',shopAddress:'',shopPhone:'',shopTagline:'',queueEstimate:20});
DB.def('queue',[]);
DB.def('firstRun',true);
DB.def('expenses',[]);
DB.def('expense_categories',['Produk Rambut','Peralatan','Sewa','Listrik & Air','Gaji','Konsumsi','Lain-lain']);
DB.def('debts',[]);
DB.def('addons',[
  {id:'a1',name:'Pomade Gatsby',price:45000,stock:10,active:true},
  {id:'a2',name:'Shampo Makarizo',price:25000,stock:15,active:true},
  {id:'a3',name:'Hair Tonic',price:30000,stock:8,active:true},
  {id:'a4',name:'Wax Rambut',price:50000,stock:5,active:true},
]);

// ══════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════
let currentUser = null;
let pinBuffer = '';
let cart = [];
let cartBarber = '';
let calDate = new Date();

// ── HELPERS ──
function getShopName(){ const s=DB.get('settings')||{}; return s.shopName||'Pangkas'; }
function waLink(phone,msg){ const p=(phone||'').replace(/[^0-9]/g,'').replace(/^0/,'62'); return 'https://wa.me/'+p+'?text='+encodeURIComponent(msg); }

// ══════════════════════════════════════════════
// ONBOARDING (first run)
// ══════════════════════════════════════════════
function checkFirstRun(){
  const s=DB.get('settings')||{};
  if(DB.get('firstRun')===true && !s.shopName){
    document.getElementById('login').style.display='none';
    document.getElementById('app').style.display='none';
    document.getElementById('onboarding').style.display='flex';
    renderOnboarding();
    return true;
  }
  return false;
}

let obStep=1;
function renderOnboarding(){
  const el=document.getElementById('onboarding');
  const s=DB.get('settings')||{};
  el.innerHTML=`
  <div class="login-logo">
    <div style="width:80px;height:80px;margin:0 auto;background:var(--s1);border-radius:50%;border:2px solid var(--teal);display:flex;align-items:center;justify-content:center;font-size:2rem">💈</div>
    <div class="brand">PANGKAS</div>
    <div class="sub">Setup Awal</div>
  </div>
  <div class="login-card" style="width:340px">
    <div style="display:flex;justify-content:center;gap:.5rem;margin-bottom:1rem">
      <div style="width:10px;height:10px;border-radius:50%;background:${obStep>=1?'var(--teal)':'var(--b1)'}"></div>
      <div style="width:10px;height:10px;border-radius:50%;background:${obStep>=2?'var(--teal)':'var(--b1)'}"></div>
      <div style="width:10px;height:10px;border-radius:50%;background:${obStep>=3?'var(--teal)':'var(--b1)'}"></div>
    </div>
    ${obStep===1?`
      <h3>📍 Info Toko</h3>
      <p style="font-size:.72rem;color:var(--ash);margin-bottom:.8rem">Langkah 1 dari 3</p>
      <div class="field"><label>Nama Toko *</label><input class="finp" id="ob-name" placeholder="Contoh: Rome Bois Barbershop" value="${s.shopName||''}"></div>
      <div class="field"><label>Alamat</label><input class="finp" id="ob-addr" placeholder="Jl. Raya No. 1" value="${s.shopAddress||''}"></div>
      <div class="field"><label>No HP / WhatsApp</label><input class="finp" id="ob-phone" placeholder="08xx-xxxx-xxxx" value="${s.shopPhone||''}"></div>
      <button class="btn btn-teal btn-full" onclick="obNext1()">Lanjut →</button>
    `:''}
    ${obStep===2?`
      <h3>✂️ Layanan</h3>
      <p style="font-size:.72rem;color:var(--ash);margin-bottom:.8rem">Langkah 2 — layanan default sudah disiapkan, bisa diedit nanti di Admin</p>
      <div style="text-align:left">
      ${(DB.get('services')||[]).map(s=>`<div style="display:flex;justify-content:space-between;padding:.3rem 0;font-size:.8rem;border-bottom:1px solid rgba(255,255,255,.04)"><span>${s.name}</span><span style="color:var(--teal)">${rp(s.price)}</span></div>`).join('')}
      </div>
      <div style="display:flex;gap:.5rem;margin-top:1rem">
        <button class="btn btn-outline" onclick="obStep=1;renderOnboarding()">← Kembali</button>
        <button class="btn btn-teal" style="flex:1" onclick="obStep=3;renderOnboarding()">Lanjut →</button>
      </div>
    `:''}
    ${obStep===3?`
      <h3>👤 Admin Pertama</h3>
      <p style="font-size:.72rem;color:var(--ash);margin-bottom:.8rem">Langkah 3 — buat akun admin</p>
      <div class="field"><label>Nama</label><input class="finp" id="ob-admin-name" placeholder="Nama kamu" value="Admin"></div>
      <div class="field"><label>PIN (4 digit)</label><input class="finp" id="ob-admin-pin" type="number" maxlength="4" placeholder="1234"></div>
      <div style="display:flex;gap:.5rem;margin-top:1rem">
        <button class="btn btn-outline" onclick="obStep=2;renderOnboarding()">← Kembali</button>
        <button class="btn btn-teal" style="flex:1" onclick="obFinish()">Mulai Pangkas! 🚀</button>
      </div>
    `:''}
  </div>
  <div style="font-size:.65rem;color:var(--ash);margin-top:1rem">Powered by Pangkas 💈</div>`;
}

function obNext1(){
  const name=document.getElementById('ob-name')?.value?.trim();
  if(!name){alert('Nama toko wajib diisi');return;}
  const s=DB.get('settings')||{};
  s.shopName=name;
  s.shopAddress=document.getElementById('ob-addr')?.value?.trim()||'';
  s.shopPhone=document.getElementById('ob-phone')?.value?.trim()||'';
  DB.set('settings',s);
  obStep=2;renderOnboarding();
}

function obFinish(){
  const name=document.getElementById('ob-admin-name')?.value?.trim()||'Admin';
  const pin=String(document.getElementById('ob-admin-pin')?.value||'').trim();
  if(pin.length!==4){alert('PIN harus 4 digit');return;}
  const users=DB.get('users')||[];
  // Replace default user or add new
  const existing=users.findIndex(u=>u.id==='anang');
  const newUser={id:'admin-'+Date.now(),name,pin,role:'admin'};
  if(existing>=0) users[existing]=newUser; else users.push(newUser);
  DB.set('users',users);
  DB.set('firstRun',false);
  document.getElementById('onboarding').style.display='none';
  document.getElementById('login').style.display='flex';
  // Update login screen brand
  updateLoginBrand();
}

function updateLoginBrand(){
  const el=document.getElementById('loginBrand');
  if(el) el.textContent=getShopName().toUpperCase();
  const logo=document.getElementById('topLogo');
  if(logo) logo.textContent='💈 '+getShopName();
}

// ══════════════════════════════════════════════
// LOGIN
// ══════════════════════════════════════════════
// Check first run on load
if(!checkFirstRun()){
  updateLoginBrand();
}

function pinKey(k){
  if(pinBuffer.length>=4) return;
  pinBuffer+=k;
  updatePinDots();
  if(pinBuffer.length===4) setTimeout(tryLogin,200);
}
function pinDel(){ pinBuffer=pinBuffer.slice(0,-1); updatePinDots(); }
function pinClear(){ pinBuffer=''; updatePinDots(); document.getElementById('loginErr').textContent=''; }
function updatePinDots(){
  for(let i=0;i<4;i++){
    document.getElementById('pd'+i).classList.toggle('filled',i<pinBuffer.length);
  }
}
function tryLogin(){
  const users = DB.get('users')||[];
  const u = users.find(x=>x.pin===pinBuffer);
  if(u){
    currentUser=u;
    document.getElementById('login').style.display='none';
    document.getElementById('app').style.display='flex';
    document.getElementById('topUser').textContent=u.name+(u.role==='admin'?' 👑':'');
    buildNav();
    showTab('home');
  } else {
    document.getElementById('loginErr').textContent='PIN salah, coba lagi';
    pinBuffer='';
    updatePinDots();
    setTimeout(()=>document.getElementById('loginErr').textContent='',2000);
  }
}
function logout(){
  currentUser=null; pinBuffer=''; updatePinDots();
  document.getElementById('app').style.display='none';
  document.getElementById('login').style.display='flex';
}

// ══════════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════════
const TABS_ALL   = [{id:'home',icon:'🏠',label:'Home'},{id:'kasir',icon:'💰',label:'Kasir'},{id:'antrian',icon:'📋',label:'Antrian'},{id:'janji',icon:'📅',label:'Janji'},{id:'member',icon:'👥',label:'Member'},{id:'birthday',icon:'🎂',label:'Ultah'},{id:'laporan',icon:'📊',label:'Laporan'},{id:'hutang',icon:'📒',label:'Hutang'},{id:'belanja',icon:'🛒',label:'Belanja'},{id:'admin',icon:'⚙️',label:'Admin'}];
const TABS_BARBER= [{id:'home',icon:'🏠',label:'Home'},{id:'kasir',icon:'💰',label:'Kasir'},{id:'antrian',icon:'📋',label:'Antrian'},{id:'janji',icon:'📅',label:'Janji'}];

function buildNav(){
  const tabs = currentUser.role==='admin'?TABS_ALL:TABS_BARBER;
  const nav=document.getElementById('mainNav');
  const panels=document.getElementById('panels');
  nav.innerHTML=''; panels.innerHTML='';
  tabs.forEach(t=>{
    const btn=document.createElement('button');
    btn.className='ntab'; btn.id='tab-'+t.id;
    btn.innerHTML=t.icon+' '+t.label;
    btn.onclick=()=>showTab(t.id);
    nav.appendChild(btn);
    const p=document.createElement('div');
    p.className='panel'; p.id='panel-'+t.id;
    panels.appendChild(p);
  });
}

function showTab(id){
  document.querySelectorAll('.ntab').forEach(b=>b.classList.remove('on'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('on'));
  // Always reset cart when switching to kasir
  if(id==='kasir'){ cart=[]; selectedPayMethod=null; }
  const tb=document.getElementById('tab-'+id);
  const pb=document.getElementById('panel-'+id);
  if(tb) tb.classList.add('on');
  if(pb){ pb.classList.add('on'); renderPanel(id); }
}

function renderPanel(id){
  const el=document.getElementById('panel-'+id);
  if(!el) return;
  if(id==='home') renderHome(el);
  else if(id==='kasir') renderKasir(el);
  else if(id==='antrian') renderAntrian(el);
  else if(id==='janji') renderJanji(el);
  else if(id==='member') renderMember(el);
  else if(id==='birthday') renderBirthday(el);
  else if(id==='laporan') renderLaporan(el);
  else if(id==='hutang') renderHutang(el);
  else if(id==='belanja') renderBelanja(el);
  else if(id==='admin') renderAdmin(el);
}

// ══════════════════════════════════════════════
// ══════════════════════════════════════════════
// HOME DASHBOARD
// ══════════════════════════════════════════════
function renderHome(el){
  const txs=DB.get('transactions')||[];
  const now=new Date();
  const todayTx=txs.filter(t=>{const d=new Date(t.date);return d.toDateString()===now.toDateString()});
  const paidToday=todayTx.filter(t=>!t.isHutang);
  const totalToday=paidToday.reduce((a,t)=>a+t.total,0);
  const queue=DB.get('queue')||[];
  const activeQueue=queue.filter(q=>q.status==='waiting'||q.status==='serving');
  const members=DB.get('members')||[];
  const settings=DB.get('settings')||{};
  const commToday=paidToday.reduce((a,t)=>a+t.commission,0);

  el.innerHTML=`
  <div class="card">
    <div class="card-title">📊 Dashboard — ${now.toLocaleDateString('id-ID',{weekday:'long',day:'numeric',month:'long',year:'numeric'})}</div>
    <div class="grid2" style="margin-bottom:.5rem">
      <div class="stat-card"><div class="stat-val rp-val">${rp(totalToday)}</div><div class="stat-lbl">Pendapatan Hari Ini</div></div>
      <div class="stat-card"><div class="stat-val">${todayTx.length}</div><div class="stat-lbl">Transaksi</div></div>
    </div>
    <div class="grid3">
      <div class="stat-card"><div class="stat-val" style="color:var(--gold)">${activeQueue.length}</div><div class="stat-lbl">Antrian Aktif</div></div>
      <div class="stat-card"><div class="stat-val">${members.length}</div><div class="stat-lbl">Member</div></div>
      <div class="stat-card"><div class="stat-val rp-val" style="font-size:1rem">${rp(commToday)}</div><div class="stat-lbl">Komisi Hari Ini</div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">⚡ Aksi Cepat</div>
    <div class="grid2">
      <button class="btn btn-teal btn-full" onclick="showTab('kasir')">💰 Transaksi Baru</button>
      <button class="btn btn-outline btn-full" onclick="showTab('antrian')">📋 Tambah Antrian</button>
    </div>
  </div>
  ${todayTx.length>0?`
  <div class="card">
    <div class="card-title">🕐 Transaksi Terakhir</div>
    <table class="tbl">
      <thead><tr><th>Waktu</th><th>Customer</th><th>Total</th><th>Bayar</th></tr></thead>
      <tbody>${[...todayTx].reverse().slice(0,5).map(t=>`
      <tr>
        <td style="font-family:monospace;font-size:.68rem">${new Date(t.date).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})}</td>
        <td>${t.customer}</td>
        <td style="color:${t.isHutang?'var(--ember)':'var(--teal)'};font-weight:600">${rp(t.total)}</td>
        <td><span class="badge badge-${t.isHutang?'red':t.payMethod==='qris'?'teal':t.payMethod==='tf'?'gold':'gray'}">${t.isHutang?'Hutang':t.payMethod==='qris'?'QRIS':t.payMethod==='tf'?'TF':'Cash'}</span></td>
      </tr>`).join('')}</tbody>
    </table>
  </div>`:'<div class="card"><div class="empty-state"><div class="ei">☀️</div><p>Belum ada transaksi hari ini</p></div></div>'}
  ${settings.shopName?'':'<div class="card" style="border-color:rgba(245,158,11,.3)"><div style="display:flex;align-items:center;gap:.5rem;font-size:.78rem;color:var(--gold)">⚠️ Nama toko belum diatur — buka Admin → Info Toko</div></div>'}`;
}

// ══════════════════════════════════════════════
// ANTRIAN / QUEUE
// ══════════════════════════════════════════════
function renderAntrian(el){
  // Auto-reset: clear old queue items
  let queue=DB.get('queue')||[];
  const today=new Date().toDateString();
  queue=queue.filter(q=>new Date(q.createdAt).toDateString()===today || q.status==='waiting' || q.status==='serving');
  DB.set('queue',queue);

  const waiting=queue.filter(q=>q.status==='waiting');
  const serving=queue.filter(q=>q.status==='serving');
  const done=queue.filter(q=>q.status==='done');
  const settings=DB.get('settings')||{queueEstimate:20};
  const est=settings.queueEstimate||20;

  el.innerHTML=`
  <div class="card">
    <div class="card-title">📋 Antrian Hari Ini
      <button class="btn btn-teal btn-sm" onclick="openAddQueue()">+ Walk-in</button>
    </div>
    <div class="grid3" style="margin-bottom:.75rem">
      <div class="stat-card"><div class="stat-val" style="color:var(--gold)">${waiting.length}</div><div class="stat-lbl">Menunggu</div></div>
      <div class="stat-card"><div class="stat-val" style="color:var(--teal)">${serving.length}</div><div class="stat-lbl">Dilayani</div></div>
      <div class="stat-card"><div class="stat-val" style="color:var(--ash)">${done.length}</div><div class="stat-lbl">Selesai</div></div>
    </div>
    ${waiting.length===0&&serving.length===0?'<div class="empty-state"><div class="ei">📋</div><p>Belum ada antrian</p></div>':''}
    ${serving.map(q=>`
    <div style="background:rgba(10,191,188,.08);border:1px solid rgba(10,191,188,.3);border-radius:12px;padding:.75rem;margin-bottom:.5rem">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <span style="font-size:1.3rem;font-weight:800;color:var(--teal);margin-right:.5rem">#${q.number}</span>
          <span style="font-weight:700">${q.name}</span>
          <span class="badge badge-teal" style="margin-left:.3rem">Dilayani</span>
        </div>
        <button class="btn btn-sm btn-teal" onclick="queueDone('${q.id}')">✅ Selesai</button>
      </div>
      <div style="font-size:.72rem;color:var(--ash);margin-top:.3rem">✂️ ${q.service} · 🧑 ${q.barber||'-'}</div>
    </div>`).join('')}
    ${waiting.map((q,i)=>`
    <div style="background:var(--s2);border:1px solid var(--b1);border-radius:12px;padding:.75rem;margin-bottom:.5rem">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <span style="font-size:1.3rem;font-weight:800;color:var(--gold);margin-right:.5rem">#${q.number}</span>
          <span style="font-weight:700">${q.name}</span>
          <span class="badge badge-gold" style="margin-left:.3rem">Menunggu</span>
          <span style="font-size:.68rem;color:var(--ash);margin-left:.3rem">~${(i+1)*est} mnt</span>
        </div>
        <div style="display:flex;gap:.3rem">
          <button class="btn btn-sm btn-teal" onclick="queueServe('${q.id}')">Mulai</button>
          <button class="btn btn-sm btn-danger" onclick="queueCancel('${q.id}')">Batal</button>
        </div>
      </div>
      <div style="font-size:.72rem;color:var(--ash);margin-top:.3rem">✂️ ${q.service}</div>
    </div>`).join('')}
  </div>
  ${done.length>0?`
  <div class="card">
    <div class="card-title" style="color:var(--ash)">✅ Selesai Hari Ini (${done.length})</div>
    ${done.map(q=>`<div style="display:flex;justify-content:space-between;padding:.3rem 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:.78rem;opacity:.5"><span>#${q.number} ${q.name} — ${q.service}</span><span>${new Date(q.doneAt||q.createdAt).toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'})}</span></div>`).join('')}
  </div>`:''}`;
}

function openAddQueue(){
  const svcs=(DB.get('services')||[]).filter(s=>s.active);
  openModal(`<h3>📋 Tambah Antrian</h3>
    <div class="field"><label>Nama Customer</label><input class="finp" id="q-name" placeholder="Nama"></div>
    <div class="field"><label>Layanan</label><select class="finp" id="q-svc">${svcs.map(s=>`<option value="${s.name}">${s.name}</option>`).join('')}</select></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveQueue()">Tambah</button>
    </div>`);
}

function saveQueue(){
  const name=document.getElementById('q-name')?.value?.trim();
  const svc=document.getElementById('q-svc')?.value;
  if(!name){alert('Nama wajib diisi');return;}
  const queue=DB.get('queue')||[];
  const todayQueue=queue.filter(q=>new Date(q.createdAt).toDateString()===new Date().toDateString());
  const nextNum=(todayQueue.length>0?Math.max(...todayQueue.map(q=>q.number||0)):0)+1;
  queue.push({id:'q-'+Date.now(),name,service:svc,number:nextNum,status:'waiting',barber:'',createdAt:new Date().toISOString()});
  DB.set('queue',queue);
  closeModal();
  renderAntrian(document.getElementById('panel-antrian'));
}

function queueServe(id){
  const queue=DB.get('queue')||[];
  const q=queue.find(x=>x.id===id);
  if(q) q.status='serving';
  DB.set('queue',queue);
  renderAntrian(document.getElementById('panel-antrian'));
}

function queueDone(id){
  const queue=DB.get('queue')||[];
  const q=queue.find(x=>x.id===id);
  if(q){q.status='done';q.doneAt=new Date().toISOString();}
  DB.set('queue',queue);
  renderAntrian(document.getElementById('panel-antrian'));
}

function queueCancel(id){
  if(!confirm('Hapus dari antrian?')) return;
  DB.set('queue',(DB.get('queue')||[]).filter(q=>q.id!==id));
  renderAntrian(document.getElementById('panel-antrian'));
}

// ══════════════════════════════════════════════
// KASIR
// ══════════════════════════════════════════════
function renderKasir(el){
  const svcs=(DB.get('services')||[]).filter(s=>s.active);
  const users=DB.get('users')||[];
  const barbers=users;
  el.innerHTML=`
  <div class="card">
    <div class="card-title">Pilih Layanan</div>
    <div class="service-grid" id="svcGrid"></div>
  </div>
  <div class="card">
    <div class="card-title">Add-ons & Produk</div>
    <div class="service-grid" id="addonGrid"></div>
  </div>
  <div class="card">
    <div class="card-title">Detail Transaksi
      <button class="btn btn-outline btn-sm" onclick="clearCart()">Bersihkan</button>
    </div>
    <div class="field">
      <label>Nama Customer</label>
      <input class="finp" id="custName" placeholder="Nama customer (opsional)">
    </div>
    <div class="field">
      <label>Barber</label>
      <select class="finp" id="barberSel">
        ${barbers.map(b=>`<option value="${b.id}">${b.name}</option>`).join('')}
      </select>
    </div>
    <div id="cartList"></div>
    <div class="cart-total" id="cartTotal">Total: Rp 0</div>
    <button class="btn btn-teal btn-full" onclick="checkout()" style="margin-top:.3rem">💳 Bayar & Cetak Struk</button>
  </div>`;
  cart=[];
  selectedPayMethod=null;
  renderSvcGrid();
  renderAddonGrid();
  renderCart();
}

function renderSvcGrid(){
  const svcs=(DB.get('services')||[]).filter(s=>s.active);
  const grid=document.getElementById('svcGrid');
  if(!grid) return;
  grid.innerHTML='';
  svcs.forEach(s=>{
    const qty=cart.filter(c=>c.id===s.id).length;
    const btn=document.createElement('div');
    btn.className='svc-btn'+(qty>0?' sel':'');
    btn.innerHTML=(qty>0?`<div class="svc-qty">${qty}</div>`:'')+
      `<div class="svc-name">${s.name}</div><div class="svc-price">${rp(s.price)}</div>`;
    btn.onclick=()=>{ cart.push({id:s.id,name:s.name,price:s.price}); renderSvcGrid(); renderCart(); };
    grid.appendChild(btn);
  });
}

function renderAddonGrid(){
  const addons=(DB.get('addons')||[]).filter(a=>a.active);
  const grid=document.getElementById('addonGrid');
  if(!grid) return;
  grid.innerHTML='';
  if(addons.length===0){
    grid.innerHTML='<div style="color:var(--ash);font-size:.75rem;padding:.3rem">Belum ada produk add-on</div>';
    return;
  }
  addons.forEach(a=>{
    const qty=cart.filter(c=>c.id==='ao-'+a.id).length;
    const inCartNow=cart.filter(c=>c.addonId===a.id).length;
    const stockLimit=a.stock!=null?a.stock:999;
    const outOfStock=(a.stock!==undefined&&a.stock<=0)||(inCartNow>=stockLimit&&stockLimit<999);
    const btn=document.createElement('div');
    btn.className='svc-btn'+(qty>0?' sel':'')+(outOfStock?' disabled':'');
    btn.style.opacity=outOfStock?'0.4':'1';
    const stockColor = outOfStock ? '#fca5a5' : '#52526e';
    const stockVal = a.stock != null ? a.stock : '~';
    btn.innerHTML = (qty > 0 ? '<div class="svc-qty">'+qty+'</div>' : '') +
      '<div class="svc-name">'+a.name+'</div>' +
      '<div class="svc-price">'+rp(a.price)+'</div>' +
      '<div style="font-size:.6rem;color:'+stockColor+';margin-top:2px">Stok: '+(stockLimit<999?Math.max(0,stockLimit-inCartNow)+'/'+stockLimit:stockVal)+'</div>';
    if(!outOfStock){
      btn.onclick=()=>{
        // Count how many of this addon already in cart
        const inCart=cart.filter(c=>c.addonId===a.id).length;
        const stock=a.stock!=null?a.stock:999;
        if(inCart>=stock){
          // Flash the button red briefly
          btn.style.borderColor='var(--ember)';
          btn.style.background='rgba(239,68,68,.12)';
          setTimeout(()=>{ btn.style.borderColor=''; btn.style.background=''; },800);
          return;
        }
        cart.push({id:'ao-'+a.id+'-'+Date.now(),name:a.name,price:a.price,isAddon:true,addonId:a.id});
        renderAddonGrid(); renderCart(); // re-render so button greyed if now at stock limit
      };
    }
    grid.appendChild(btn);
  });
}

function renderCart(){
  const list=document.getElementById('cartList');
  const totalEl=document.getElementById('cartTotal');
  if(!list) return;
  list.innerHTML='';
  const grouped={};
  cart.forEach(c=>{ grouped[c.id]=grouped[c.id]||{...c,qty:0}; grouped[c.id].qty++; });
  Object.values(grouped).forEach(c=>{
    const d=document.createElement('div');
    d.className='cart-item';
    const left=document.createElement('span');
    left.textContent=c.name+' x'+c.qty;
    const right=document.createElement('div');
    right.style.cssText='display:flex;align-items:center;gap:.5rem';
    const price=document.createElement('span');
    price.style.color='var(--teal)';
    price.textContent=rp(c.price*c.qty);
    const btn=document.createElement('button');
    btn.style.cssText='background:none;border:none;color:var(--ember);cursor:pointer;font-size:.9rem';
    btn.textContent='✕';
    btn.onclick=()=>{ removeFromCart(c.id); };
    right.appendChild(price); right.appendChild(btn);
    d.appendChild(left); d.appendChild(right);
    list.appendChild(d);
  });
  const total=cart.reduce((a,c)=>a+c.price,0);
  if(totalEl) totalEl.textContent='Total: '+rp(total);
}

function removeFromCart(id){
  const idx=cart.findLastIndex(c=>c.id===id);
  if(idx>=0) cart.splice(idx,1);
  renderSvcGrid(); renderCart();
}
function clearCart(){ cart=[]; renderSvcGrid(); renderCart(); }

function checkout(){
  if(cart.length===0){ alert('Pilih layanan dulu!'); return; }
  const name=document.getElementById('custName')?.value?.trim()||'Pelanggan';
  const barberId=document.getElementById('barberSel')?.value;
  const total=cart.reduce((a,c)=>a+c.price,0);
  // Show payment method modal using DOM
  const box = document.getElementById('modalBox');
  const methods = [
    {id:'cash', icon:'\u{1F4B5}', label:'Cash', color:''},
    {id:'tf',   icon:'\u{1F3E6}', label:'Transfer', color:''},
    {id:'qris', icon:'\u{1F4F1}', label:'QRIS', color:''},
    {id:'hutang',icon:'\u{1F4D2}',label:'Hutang', color:'var(--ember)'}
  ];
  box.innerHTML = '';
  const h3 = document.createElement('h3');
  h3.textContent = 'Metode Pembayaran';
  box.appendChild(h3);
  const sub = document.createElement('div');
  sub.style.cssText = 'font-size:.85rem;color:var(--ash);margin-bottom:1rem';
  sub.innerHTML = 'Total: <strong style="color:var(--teal);font-size:1.1rem">'+rp(total)+'</strong>';
  box.appendChild(sub);
  const grid = document.createElement('div');
  grid.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:.5rem;margin-bottom:1rem';
  methods.forEach(function(m){
    const btn = document.createElement('button');
    btn.className = 'pay-btn';
    btn.id = 'pay-'+m.id;
    if(m.color) btn.style.color = m.color;
    btn.innerHTML = '<div style="font-size:1.3rem">'+m.icon+'</div><div>'+m.label+'</div>';
    btn.onclick = function(){ selectPay(m.id); };
    grid.appendChild(btn);
  });
  box.appendChild(grid);
  const noteDiv = document.createElement('div');
  noteDiv.id = 'hutang-note';
  noteDiv.style.display = 'none';
  noteDiv.innerHTML = '<div class="field"><label>Catatan Hutang (opsional)</label><input class="finp" id="debt-note" placeholder="Bayar Jumat depan"></div>';
  box.appendChild(noteDiv);
  const footer = document.createElement('div');
  footer.className = 'modal-footer';
  const cancelBtn = document.createElement('button');
  cancelBtn.className = 'btn btn-outline';
  cancelBtn.textContent = 'Batal';
  cancelBtn.onclick = closeModal;
  const confirmBtn = document.createElement('button');
  confirmBtn.className = 'btn btn-teal';
  confirmBtn.id = 'confirmPayBtn';
  confirmBtn.textContent = 'Konfirmasi';
  confirmBtn.disabled = true;
  confirmBtn.onclick = confirmCheckout;
  footer.appendChild(cancelBtn);
  footer.appendChild(confirmBtn);
  box.appendChild(footer);
  document.getElementById('modalOverlay').classList.add('open');
}

let selectedPayMethod = null;
let discountMode = 'none'; // 'none' | 'pct' | 'rp'
let discountVal = 0;       // percentage or rp amount
let discountType = 'pct';  // for custom: 'pct' or 'rp'
let rewardClaimed = false;

function setDisc(mode, val){
  // Reset all chips
  ['dc-none','dc-10','dc-20','dc-50','dc-custom'].forEach(id=>{
    const el=document.getElementById(id);
    if(el) el.classList.remove('on');
  });
  const customInp=document.getElementById('discCustomInput');
  const preview=document.getElementById('discPreview');
  if(mode==='none'){
    discountMode='none'; discountVal=0;
    document.getElementById('dc-none')?.classList.add('on');
    if(customInp) customInp.style.display='none';
    if(preview) preview.style.display='none';
  } else if(mode==='pct'){
    discountMode='pct'; discountVal=val;
    document.getElementById('dc-'+val)?.classList.add('on');
    if(customInp) customInp.style.display='none';
    updateDiscPreview();
  } else if(mode==='custom'){
    discountMode='custom'; discountVal=0;
    document.getElementById('dc-custom')?.classList.add('on');
    if(customInp) customInp.style.display='flex';
    const v=document.getElementById('discCustomVal');
    if(v) v.value='';
  }
  renderCart();
}

function setDiscType(type){
  discountType=type;
  ['dc-type-pct','dc-type-rp'].forEach(id=>document.getElementById(id)?.classList.remove('on'));
  document.getElementById('dc-type-'+type)?.classList.add('on');
  calcDisc();
}

function calcDisc(){
  const v=parseInt(document.getElementById('discCustomVal')?.value)||0;
  discountVal=v;
  updateDiscPreview();
  renderCart();
}

function getDiscountAmount(subtotal){
  if(discountMode==='none') return 0;
  if(rewardClaimed) return 0; // reward handles its own discount
  if(discountMode==='pct') return Math.round(subtotal*(discountVal/100));
  if(discountMode==='custom'){
    if(discountType==='pct') return Math.round(subtotal*(discountVal/100));
    return Math.min(discountVal, subtotal);
  }
  return 0;
}

function updateDiscPreview(){
  const preview=document.getElementById('discPreview');
  if(!preview) return;
  const subtotal=cart.reduce((a,c)=>a+c.price,0);
  const disc=getDiscountAmount(subtotal);
  if(disc>0){
    preview.style.display='block';
    preview.textContent='Diskon: -'+rp(disc)+' → Total: '+rp(subtotal-disc);
  } else preview.style.display='none';
}

function claimReward(){
  const custName=document.getElementById('custName')?.value?.trim();
  if(!custName) return;
  const members=DB.get('members')||[];
  const m=members.find(x=>x.name.toLowerCase()===custName.toLowerCase());
  if(!m) return;
  const settings=DB.get('settings')||{memberVisits:10};
  const target=settings.memberVisits||10;
  const cycleProgress=(m.visits||0)%target;
  if(cycleProgress!==0&&(m.visits||0)<target) return;
  rewardClaimed=true;
  // Visual feedback
  const btn=document.querySelector('#rewardAlert button');
  if(btn){btn.textContent='✅ Diklaim!';btn.disabled=true;}
  renderCart();
}

function resetPromo(){
  discountMode='none'; discountVal=0; discountType='pct'; rewardClaimed=false;
  setDisc('none',0);
}
function selectPay(method){
  selectedPayMethod=method;
  document.querySelectorAll('.pay-btn').forEach(b=>b.classList.remove('pay-sel'));
  document.getElementById('pay-'+method)?.classList.add('pay-sel');
  document.getElementById('confirmPayBtn').disabled=false;
  document.getElementById('hutang-note').style.display=method==='hutang'?'block':'none';
}

function confirmCheckout(){
  if(!selectedPayMethod) return;
  const name=document.getElementById('custName')?.value?.trim()||'Pelanggan';
  const barberId=document.getElementById('barberSel')?.value;
  const barbers=DB.get('users')||[];
  const barber=barbers.find(b=>b.id===barberId)||{name:barberId};
  const settings=DB.get('settings')||{commission:40};
  const total=cart.reduce((a,c)=>a+c.price,0);
  const isHutang=selectedPayMethod==='hutang';
  const commission=isHutang?0:Math.round(total*settings.commission/100);
  const debtNote=document.getElementById('debt-note')?.value?.trim()||'';
  const tx={
    id:'tx-'+Date.now(),
    date:new Date().toISOString(),
    customer:name,
    barber:barber.name,
    barberId,
    items:[...cart],
    total,
    commission,
    payMethod:selectedPayMethod,
    isHutang
  };
  // Save transaction (hutang = 0 commission, mark as unpaid)
  const txs=DB.get('transactions')||[];
  txs.push(tx);
  DB.set('transactions',txs);
  // If hutang — create debt record
  if(isHutang){
    const debts=DB.get('debts')||[];
    debts.push({
      id:'debt-'+Date.now(),
      txId:tx.id,
      customer:name,
      barber:barber.name,
      amount:total,
      note:debtNote,
      date:new Date().toISOString(),
      paid:false,
      paidAt:null
    });
    DB.set('debts',debts);
  }
  // Deduct addon stock
  const addons=DB.get('addons')||[];
  cart.filter(c=>c.isAddon).forEach(c=>{
    const a=addons.find(x=>x.id===c.addonId);
    if(a&&a.stock>0) a.stock--;
  });
  DB.set('addons',addons);
  updateMemberVisit(name);
  closeModal();
  printStruk(tx);
  // Full re-render kasir to ensure clean state
  cart=[];
  selectedPayMethod=null;
  resetPromo();
  renderPanel('kasir');
}

function printStruk(tx){
  const settings=DB.get('settings')||{};
  const d=new Date(tx.date);
  const dateStr=d.toLocaleDateString('id-ID',{day:'2-digit',month:'long',year:'numeric'});
  const timeStr=d.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
  const itemsHtml=tx.items.map(i=>'<div style="display:flex;justify-content:space-between"><span>'+i.name+'</span><span>'+rp(i.price)+'</span></div>').join('');
  const payLabel = tx.isHutang ? 'HUTANG' : tx.payMethod==='qris' ? 'QRIS' : tx.payMethod==='tf' ? 'Transfer' : 'Cash';
  document.getElementById('struk-print').innerHTML =
    '<div style="text-align:center;margin-bottom:8px">' +
      '<div style="font-size:14px;font-weight:800;letter-spacing:2px">'+getShopName()+'</div>' +
      '<div style="font-size:10px">Terima kasih telah berkunjung</div>' +
    '</div>' +
    '<div class="struk-line"></div>' +
    '<div style="font-size:10px;margin-bottom:4px">' +
      '<div>Tgl: ' + dateStr + ' ' + timeStr + '</div>' +
      '<div>Customer: ' + tx.customer + '</div>' +
      '<div>Barber: ' + tx.barber + '</div>' +
      '<div>No: ' + tx.id.slice(-6).toUpperCase() + '</div>' +
    '</div>' +
    '<div class="struk-line"></div>' +
    '<div style="font-size:10px;margin-bottom:4px">' + itemsHtml + '</div>' +
    '<div class="struk-line"></div>' +
    '<div style="display:flex;justify-content:space-between;font-weight:800;font-size:12px">' +
      '<span>TOTAL</span><span>' + rp(tx.total) + '</span>' +
    '</div>' +
    '<div style="font-size:10px;margin-top:2px">Bayar: ' + payLabel + '</div>' +
    '<div class="struk-line"></div>' +
    '<div style="text-align:center;font-size:10px;margin-top:6px">' +
      '<div>Sampai jumpa lagi!</div>' +
    '</div>';
  window.print();
}

// ══════════════════════════════════════════════
// ATUR JANJI
// ══════════════════════════════════════════════
function renderJanji(el){
  const now=new Date();
  el.innerHTML=`
  <div class="card">
    <div class="cal-header">
      <button class="cal-nav" onclick="calPrev()">◀</button>
      <div style="font-weight:700;font-size:.9rem" id="calMonthLabel"></div>
      <button class="cal-nav" onclick="calNext()">▶</button>
    </div>
    <div class="cal-days" id="calDays"></div>
    <div id="calGrid"></div>
  </div>
  <div class="card">
    <div class="card-title">Janji Hari Ini <span id="todayLabel"></span>
      <button class="btn btn-teal btn-sm" onclick="openAddJanji()">+ Tambah</button>
    </div>
    <div id="apptList"></div>
  </div>`;
  renderCal();
  renderApptList(new Date());
}

function renderCal(){
  const days=['Min','Sen','Sel','Rab','Kam','Jum','Sab'];
  const year=calDate.getFullYear(), month=calDate.getMonth();
  const firstDay=new Date(year,month,1).getDay();
  const daysInMonth=new Date(year,month+1,0).getDate();
  const monthNames=['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  document.getElementById('calMonthLabel').textContent=monthNames[month]+' '+year;
  const appts=DB.get('appointments')||[];
  const grid=document.getElementById('calGrid');
  if(!grid) return;
  // Day labels
  grid.innerHTML='<div class="cal-days">'+days.map(d=>`<div class="cal-day-lbl">${d}</div>`).join('')+'</div>';
  const daysDiv=document.createElement('div');
  daysDiv.className='cal-days';
  // Empty cells
  for(let i=0;i<firstDay;i++){
    const e=document.createElement('div');e.className='cal-day empty';daysDiv.appendChild(e);
  }
  const today=new Date();
  for(let d=1;d<=daysInMonth;d++){
    const dateStr=`${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const hasAppt=appts.some(a=>a.date===dateStr);
    const isToday=today.getDate()===d&&today.getMonth()===month&&today.getFullYear()===year;
    const div=document.createElement('div');
    div.className='cal-day'+(isToday?' today':'')+(hasAppt?' has-appt':'');
    div.textContent=d;
    div.onclick=()=>{ renderApptList(new Date(year,month,d)); };
    daysDiv.appendChild(div);
  }
  grid.appendChild(daysDiv);
}
function calPrev(){ calDate.setMonth(calDate.getMonth()-1); renderCal(); }
function calNext(){ calDate.setMonth(calDate.getMonth()+1); renderCal(); }

function renderApptList(date){
  const dateStr=`${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
  const appts=(DB.get('appointments')||[]).filter(a=>a.date===dateStr).sort((a,b)=>a.time.localeCompare(b.time));
  const el=document.getElementById('apptList');
  const lbl=document.getElementById('todayLabel');
  if(lbl) lbl.textContent=date.toLocaleDateString('id-ID',{day:'numeric',month:'short'});
  if(!el) return;
  if(appts.length===0){el.innerHTML='<div class="empty-state"><div class="ei">📅</div><p>Belum ada janji hari ini</p></div>';return;}
  el.innerHTML='';
  appts.forEach(a=>{
    const d=document.createElement('div');d.className='appt-slot';
    d.innerHTML=`<div class="appt-time">${a.time}</div>
    <div class="appt-info"><div class="appt-name">${a.customer}</div>
    <div class="appt-detail">${a.barber} · ${a.service}${a.phone?' · 📱'+a.phone:''}</div></div>
    <span class="badge badge-${a.status==='done'?'teal':a.status==='cancel'?'red':'gold'}">${a.status==='done'?'Selesai':a.status==='cancel'?'Batal':'Menunggu'}</span>
    ${a.phone?`<a href="${waLink(a.phone,'Halo '+a.customer+'! Pengingat: jadwal potong kamu di '+getShopName()+' hari ini jam '+a.time+'. Ditunggu ya! 💈')}" target="_blank" style="background:none;border:1px solid rgba(37,211,102,.3);border-radius:6px;color:#25D366;padding:.15rem .4rem;font-size:.68rem;text-decoration:none;white-space:nowrap">📱 WA</a>`:''}
    <button onclick="deleteAppt('${a.id}')" style="background:none;border:none;color:var(--ember);cursor:pointer;margin-left:.3rem">🗑️</button>`;
    el.appendChild(d);
  });
}

function openAddJanji(){
  const users=DB.get('users')||[];
  const svcs=DB.get('services')||[];
  const today=new Date().toISOString().split('T')[0];
  openModal(`<h3>📅 Tambah Janji</h3>
    <div class="field"><label>Nama Customer</label><input class="finp" id="aj-name" placeholder="Nama customer"></div>
    <div class="field"><label>No HP (untuk WA reminder)</label><input class="finp" id="aj-phone" placeholder="08xx-xxxx-xxxx"></div>
    <div class="field"><label>Tanggal</label><input class="finp" type="date" id="aj-date" value="${today}"></div>
    <div class="field"><label>Jam</label><input class="finp" type="time" id="aj-time" value="09:00"></div>
    <div class="field"><label>Barber</label><select class="finp" id="aj-barber">${users.map(u=>`<option value="${u.name}">${u.name}</option>`).join('')}</select></div>
    <div class="field"><label>Layanan</label><select class="finp" id="aj-svc">${svcs.filter(s=>s.active).map(s=>`<option value="${s.name}">${s.name}</option>`).join('')}</select></div>
    <div class="field"><label>Catatan</label><input class="finp" id="aj-note" placeholder="Catatan (opsional)"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveAppt()">Simpan</button>
    </div>`);
}

function saveAppt(){
  const name=document.getElementById('aj-name')?.value?.trim();
  const phone=document.getElementById('aj-phone')?.value?.trim()||'';
  const date=document.getElementById('aj-date')?.value;
  const time=document.getElementById('aj-time')?.value;
  const barber=document.getElementById('aj-barber')?.value;
  const service=document.getElementById('aj-svc')?.value;
  const note=document.getElementById('aj-note')?.value;
  if(!name||!date||!time){alert('Nama, tanggal, dan jam wajib diisi');return;}
  const appts=DB.get('appointments')||[];
  appts.push({id:'ap-'+Date.now(),customer:name,phone,date,time,barber,service,note,status:'waiting',createdAt:new Date().toISOString()});
  DB.set('appointments',appts);
  closeModal();
  renderApptList(new Date(date));
  renderCal();
}

function deleteAppt(id){
  if(!confirm('Hapus janji ini?')) return;
  DB.set('appointments',(DB.get('appointments')||[]).filter(a=>a.id!==id));
  renderPanel('janji');
}

// ══════════════════════════════════════════════
// MEMBER
// ══════════════════════════════════════════════
function renderBirthday(el){
  const members=DB.get('members')||[];
  const settings=DB.get('settings')||{};
  const shopName=settings.shopName||'Pangkas';
  const today=new Date();

  // Find birthdays: today + upcoming 7 days
  function getBdayInfo(m){
    if(!m.birthday||!m.phone) return null;
    const bd=new Date(m.birthday);
    const thisYear=new Date(today.getFullYear(),bd.getMonth(),bd.getDate());
    let diff=Math.ceil((thisYear-today)/(1000*60*60*24));
    if(diff<0) diff+=365; // next year
    return {days:diff, bdStr:bd.toLocaleDateString('id-ID',{day:'numeric',month:'long'})};
  }

  const todayBdays=members.filter(m=>{
    if(!m.birthday) return false;
    const bd=new Date(m.birthday);
    return bd.getMonth()===today.getMonth()&&bd.getDate()===today.getDate();
  });

  const upcomingBdays=members.filter(m=>{
    if(!m.birthday) return false;
    const bd=new Date(m.birthday);
    const thisYear=new Date(today.getFullYear(),bd.getMonth(),bd.getDate());
    const diff=Math.ceil((thisYear-today)/(1000*60*60*24));
    return diff>0&&diff<=7;
  }).sort((a,b)=>{
    const bdA=new Date(a.birthday); const bdB=new Date(b.birthday);
    const dA=Math.ceil((new Date(today.getFullYear(),bdA.getMonth(),bdA.getDate())-today)/(1000*60*60*24));
    const dB=Math.ceil((new Date(today.getFullYear(),bdB.getMonth(),bdB.getDate())-today)/(1000*60*60*24));
    return dA-dB;
  });

  const noPhone=members.filter(m=>m.birthday&&!m.phone);

  function waCard(m, isToday){
    const info=getBdayInfo(m);
    const phone=(m.phone||'').replace(/[^0-9]/g,'').replace(/^0/,'62');
    const bdStr=info?info.bdStr:'';
    const daysLabel=isToday?'Hari ini! 🎉':(info?info.days+' hari lagi':'');
    // WA message
    const waText='Halo '+m.name+', Selamat Ulang Tahun ya! Semoga panjang umur, sehat selalu, dan semua harapan terkabul! Spesial buat kamu, ada hadiah istimewa dari kami di '+shopName+'. Dateng ya, kami tunggu! - Tim '+shopName;
    const msg=encodeURIComponent(waText);
    const waUrl='https://wa.me/'+phone+'?text='+msg;
    const cardBg=isToday
      ? 'background:linear-gradient(135deg,rgba(251,191,36,.15),rgba(251,146,60,.08));border:1px solid rgba(251,191,36,.4)'
      : 'background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08)';
    return '<div style="'+cardBg+';border-radius:14px;padding:.85rem;margin-bottom:.6rem">'+
      '<div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem">'+
        '<div>'+
          '<div style="font-weight:700;font-size:.95rem">'+(isToday?'🎂 ':'')+m.name+'</div>'+
          '<div style="font-size:.7rem;color:var(--ash);margin-top:.1rem">'+bdStr+' · '+
            '<span style="color:'+(isToday?'#fbbf24':'var(--teal)')+'">'+daysLabel+'</span>'+
          '</div>'+
          (m.phone?'<div style="font-size:.7rem;color:var(--ash);margin-top:.1rem">📱 '+m.phone+'</div>':'')+ 
        '</div>'+
        (m.phone
          ? '<a href="'+waUrl+'" target="_blank" style="display:inline-flex;align-items:center;gap:.4rem;'+
              'background:'+(isToday?'#25D366':'rgba(37,211,102,.15)')+';'+
              'color:'+(isToday?'#fff':'#25D366')+';'+
              'border:1px solid rgba(37,211,102,.4);border-radius:10px;'+
              'padding:.45rem .85rem;font-size:.78rem;font-weight:700;text-decoration:none;white-space:nowrap">'+
              '<span style="font-size:1rem">💬</span> Kontak Sekarang</a>'
          : '<button class="btn btn-sm btn-outline" onclick="editMember(&#39;'+m.id+'&#39;)">+ Tambah No HP</button>'
        )+
      '</div>'+
    '</div>';
  }

  let html='<div class="card" style="margin-bottom:.6rem">'+
    '<div class="card-title" style="color:#fbbf24">🎂 Ulang Tahun Hari Ini</div>';
  if(todayBdays.length===0){
    html+='<div style="color:var(--ash);font-size:.8rem;padding:.4rem 0">Tidak ada member yang ulang tahun hari ini</div>';
  } else {
    todayBdays.forEach(m=>{ html+=waCard(m,true); });
  }
  html+='</div>';

  if(upcomingBdays.length>0){
    html+='<div class="card" style="margin-bottom:.6rem">'+
      '<div class="card-title">📅 Ulang Tahun 7 Hari ke Depan</div>';
    upcomingBdays.forEach(m=>{ html+=waCard(m,false); });
    html+='</div>';
  }

  if(noPhone.length>0){
    html+='<div class="card">'+
      '<div class="card-title" style="font-size:.8rem;color:var(--ash)">⚠️ Belum Ada No HP ('+noPhone.length+')</div>'+
      '<div style="font-size:.75rem;color:var(--ash);margin-bottom:.5rem">Member ini punya tanggal lahir tapi belum ada nomor WA</div>';
    noPhone.forEach(m=>{
      const bd=new Date(m.birthday);
      html+='<div style="display:flex;justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05)">'+
        '<div style="font-size:.82rem">'+m.name+' · '+bd.toLocaleDateString('id-ID',{day:'numeric',month:'long'})+'</div>'+
        '<button class="btn btn-sm btn-outline" onclick="editMember(&#39;'+m.id+'&#39;)">Edit</button>'+
      '</div>';
    });
    html+='</div>';
  }

  if(members.filter(m=>m.birthday).length===0){
    html='<div class="card"><div class="empty-state">'+
      '<div class="ei">🎂</div>'+
      '<p>Belum ada member dengan tanggal lahir terdaftar</p>'+
      '<p style="font-size:.75rem;color:var(--ash)">Tambahkan tanggal lahir di tab Member → Edit</p>'+
    '</div></div>';
  }

  el.innerHTML=html;
}

function renderMember(el){
  const members=DB.get('members')||[];
  const settings=DB.get('settings')||{memberVisits:10,memberReward:'1x Potong Gratis'};
  el.innerHTML=`
  <div class="card">
    <div class="card-title">Member Aktif (${members.length})
      <button class="btn btn-teal btn-sm" onclick="openAddMember()">+ Daftarkan</button>
    </div>
    ${members.length===0?'<div class="empty-state"><div class="ei">👥</div><p>Belum ada member terdaftar</p></div>':
    members.map(m=>`
    <div class="member-card" style="margin-bottom:.6rem">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div class="member-name">${m.name}</div>
          <div class="member-visits">${m.visits||0}/${settings.memberVisits} kunjungan · ${m.phone||'-'}</div>
        </div>
        <div style="display:flex;gap:.3rem">
          ${currentUser.role==='admin'?'<button class="btn btn-sm btn-outline" onclick="addVisitManual(\''+m.id+'\')">+1</button><button class="btn btn-sm btn-danger" onclick="deleteMember(\''+m.id+'\')">&#128465;</button>':''}
        </div>
      </div>
      <div class="visit-dots">
        ${Array.from({length:settings.memberVisits},(_,i)=>`<div class="vdot${i<(m.visits||0)?' done':''}"></div>`).join('')}
      </div>
      ${(m.visits||0)>=settings.memberVisits?`<div style="margin-top:.4rem;font-size:.72rem;color:var(--teal);font-weight:700">🎉 Reward siap: ${settings.memberReward}</div>`:''}
    </div>`).join('')}
  </div>`;
}

function openAddMember(){
  const box=document.getElementById('modalBox');
  box.innerHTML='';
  const h3=document.createElement('h3'); h3.textContent='👥 Daftarkan Member'; box.appendChild(h3);
  const f1=document.createElement('div'); f1.className='field';
  f1.innerHTML='<label>Nama Lengkap</label><input class="finp" id="m-name" placeholder="Nama member">';
  box.appendChild(f1);
  const f2=document.createElement('div'); f2.className='field';
  f2.innerHTML='<label>No. HP</label><input class="finp" id="m-phone" placeholder="08xx-xxxx-xxxx">';
  box.appendChild(f2);
  const f3=document.createElement('div'); f3.className='field';
  f3.innerHTML='<label>Tanggal Lahir <span style="color:var(--ash);font-weight:400">(opsional)</span></label><input class="finp" type="date" id="m-bday">';
  box.appendChild(f3);
  const footer=document.createElement('div'); footer.className='modal-footer';
  const cancelBtn=document.createElement('button'); cancelBtn.className='btn btn-outline'; cancelBtn.textContent='Batal'; cancelBtn.onclick=closeModal;
  const saveBtn=document.createElement('button'); saveBtn.className='btn btn-teal'; saveBtn.textContent='Daftarkan'; saveBtn.onclick=saveMember;
  footer.appendChild(cancelBtn); footer.appendChild(saveBtn);
  box.appendChild(footer);
  document.getElementById('modalOverlay').classList.add('open');
}

function saveMember(){
  const name=document.getElementById('m-name')?.value?.trim();
  if(!name){alert('Nama wajib diisi');return;}
  const phone=document.getElementById('m-phone')?.value?.trim()||'';
  const birthday=document.getElementById('m-bday')?.value||null;
  const members=DB.get('members')||[];
  members.push({id:'m-'+Date.now(),name,phone,birthday,visits:0,joinDate:new Date().toISOString()});
  DB.set('members',members);
  closeModal();
  renderPanel('member');
}

function editMember(memberId){
  const members=DB.get('members')||[];
  const m=members.find(x=>x.id===memberId);
  if(!m) return;
  const box=document.getElementById('modalBox');
  box.innerHTML='';
  const h3=document.createElement('h3'); h3.textContent='✏️ Edit Member'; box.appendChild(h3);
  const f1=document.createElement('div'); f1.className='field';
  f1.innerHTML='<label>Nama</label><input class="finp" id="em-name" value="'+m.name+'">';
  box.appendChild(f1);
  const f2=document.createElement('div'); f2.className='field';
  f2.innerHTML='<label>No HP</label><input class="finp" id="em-phone" value="'+(m.phone||'')+'">';
  box.appendChild(f2);
  const f3=document.createElement('div'); f3.className='field';
  f3.innerHTML='<label>Tanggal Lahir</label><input class="finp" type="date" id="em-bday" value="'+(m.birthday||'')+'">';
  box.appendChild(f3);
  const bdPrev=document.createElement('div');
  bdPrev.style.cssText='font-size:.72rem;color:var(--teal);margin-top:-.3rem;margin-bottom:.5rem';
  box.appendChild(bdPrev);
  setTimeout(()=>{
    const bdEl=document.getElementById('em-bday');
    function showBd(){
      const v=bdEl.value; if(!v){bdPrev.textContent='';return;}
      const d=new Date(v); const today=new Date();
      const isBday=(d.getMonth()===today.getMonth()&&d.getDate()===today.getDate());
      bdPrev.textContent=(isBday?'🎂 Hari ini ulang tahun! ':'')+d.toLocaleDateString('id-ID',{day:'numeric',month:'long',year:'numeric'});
    }
    bdEl.addEventListener('change',showBd); showBd();
  },100);
  const footer=document.createElement('div'); footer.className='modal-footer';
  const cancelBtn=document.createElement('button'); cancelBtn.className='btn btn-outline'; cancelBtn.textContent='Batal'; cancelBtn.onclick=closeModal;
  const saveBtn=document.createElement('button'); saveBtn.className='btn btn-teal'; saveBtn.textContent='Simpan';
  saveBtn.onclick=function(){
    const name=document.getElementById('em-name')?.value?.trim();
    const phone=document.getElementById('em-phone')?.value?.trim();
    const birthday=document.getElementById('em-bday')?.value||null;
    if(!name){alert('Nama wajib diisi');return;}
    const mems=DB.get('members')||[];
    const mem=mems.find(x=>x.id===memberId);
    if(mem){mem.name=name;mem.phone=phone;mem.birthday=birthday;}
    DB.set('members',mems);
    closeModal(); renderPanel('member');
  };
  footer.appendChild(cancelBtn); footer.appendChild(saveBtn);
  box.appendChild(footer);
  document.getElementById('modalOverlay').classList.add('open');
}

function addVisitManual(id){
  const members=DB.get('members')||[];
  const m=members.find(x=>x.id===id);
  if(m) m.visits=(m.visits||0)+1;
  DB.set('members',members);
  renderPanel('member');
}

function deleteMember(id){
  if(!confirm('Hapus member ini?')) return;
  DB.set('members',(DB.get('members')||[]).filter(m=>m.id!==id));
  renderPanel('member');
}

function updateMemberVisit(name){
  if(!name||name==='Pelanggan') return;
  const members=DB.get('members')||[];
  const m=members.find(x=>x.name.toLowerCase()===name.toLowerCase());
  if(m){ m.visits=(m.visits||0)+1; DB.set('members',members); }
}

// ══════════════════════════════════════════════
// LAPORAN
// ══════════════════════════════════════════════
let reportPeriod='today';
function renderLaporan(el){
  el.innerHTML=`
  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.6rem">
    <div class="period-tabs" style="margin-bottom:0">
      <button class="ptab ${reportPeriod==='today'?'on':''}" onclick="setRP('today')">Hari Ini</button>
      <button class="ptab ${reportPeriod==='week'?'on':''}" onclick="setRP('week')">Minggu Ini</button>
      <button class="ptab ${reportPeriod==='month'?'on':''}" onclick="setRP('month')">Bulan Ini</button>
      <button class="ptab ${reportPeriod==='all'?'on':''}" onclick="setRP('all')">Semua</button>
    </div>
    <div style="display:flex;gap:.4rem">
      <button class="btn btn-sm btn-outline" onclick="exportCSV()">⬇️ CSV</button>
      <button class="btn btn-sm btn-outline" onclick="exportJSON()">⬇️ Backup</button>
      <label class="btn btn-sm btn-outline" style="cursor:pointer;margin:0">⬆️ Import <input type="file" accept=".json" onchange="importJSON(event)" style="display:none"></label>
    </div>
  </div>
  <div id="laporanContent"></div>`;
  renderLaporanContent();
}

function setRP(p){ reportPeriod=p; renderLaporan(document.getElementById('panel-laporan')); }

function renderLaporanContent(){
  const el=document.getElementById('laporanContent');
  if(!el) return;
  const txs=DB.get('transactions')||[];
  const now=new Date();
  const filtered=txs.filter(tx=>{
    const d=new Date(tx.date);
    if(reportPeriod==='today') return d.toDateString()===now.toDateString();
    if(reportPeriod==='week'){const w=new Date(now);w.setDate(w.getDate()-7);return d>=w;}
    if(reportPeriod==='month') return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
    return true;
  });
  // Exclude hutang (unpaid) from revenue — only count paid transactions
  const paidTx=filtered.filter(t=>!t.isHutang);
  const hutangTx=filtered.filter(t=>t.isHutang);
  const total=paidTx.reduce((a,t)=>a+t.total,0);
  const totalHutang=hutangTx.reduce((a,t)=>a+t.total,0);
  const totalComm=paidTx.reduce((a,t)=>a+t.commission,0);
  const barberMap={};
  paidTx.forEach(t=>{ barberMap[t.barber]=(barberMap[t.barber]||0)+t.commission; });
  // Expenses for same period
  const allExp=DB.get('expenses')||[];
  const filteredExp=allExp.filter(e=>{
    const d=new Date(e.date);
    if(reportPeriod==='today') return d.toDateString()===now.toDateString();
    if(reportPeriod==='week'){const w=new Date(now);w.setDate(w.getDate()-7);return d>=w;}
    if(reportPeriod==='month') return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
    return true;
  });
  const totalExp=filteredExp.reduce((a,e)=>a+e.amount,0);
  const net=total-totalComm;
  const profit=net-totalExp;
  el.innerHTML=''+
  '<div class="grid3" style="margin-bottom:.6rem">'+
    '<div class="stat-card"><div class="stat-val">'+filtered.length+'</div><div class="stat-lbl">Transaksi</div></div>'+
    '<div class="stat-card"><div class="stat-val rp-val">'+rp(total)+'</div><div class="stat-lbl">Pendapatan (Cash/TF/QRIS)</div></div>'+
    '<div class="stat-card"><div class="stat-val rp-val">'+rp(net)+'</div><div class="stat-lbl">Net (setelah komisi)</div></div>'+
  '</div>'+
  (totalHutang>0?
    '<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:12px;padding:.7rem .9rem;margin-bottom:.6rem;display:flex;align-items:center;justify-content:space-between">'+
      '<div><div style="font-size:.72rem;font-weight:700;color:#fca5a5">⚠️ Piutang Belum Lunas</div>'+
      '<div style="font-size:.72rem;color:var(--ash)">'+hutangTx.length+' transaksi belum dibayar</div></div>'+
      '<div style="font-size:1rem;font-weight:800;color:var(--ember)">'+rp(totalHutang)+'</div>'+
    '</div>':'')+
  '<div class="grid3" style="margin-bottom:.6rem">'+
    '<div class="stat-card"><div class="stat-val rp-val" style="color:var(--ember)">'+rp(totalExp)+'</div><div class="stat-lbl">Total Belanja</div></div>'+
    '<div class="stat-card"><div class="stat-val rp-val" style="color:'+(profit>=0?'var(--sage)':'var(--ember)')+'">'+rp(Math.abs(profit))+'</div><div class="stat-lbl">'+(profit>=0?'✅ Profit Bersih':'❌ Rugi')+'</div></div>'+
    '<div class="stat-card"><div class="stat-val">'+paidTx.length+'/'+filtered.length+'</div><div class="stat-lbl">Lunas / Total Tx</div></div>'+
  '</div>'+`
  <div class="card">
    <div class="card-title">Komisi per Barber</div>
    ${Object.entries(barberMap).map(([b,c])=>`
    <div style="display:flex;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:.8rem">
      <span>✂️ ${b}</span><span style="color:var(--teal);font-weight:700">${rp(c)}</span>
    </div>`).join('')||'<div style="color:var(--ash);font-size:.78rem">Belum ada data</div>'}
  </div>
  <div class="card">
    <div class="card-title">Riwayat Transaksi (${filtered.length})
      ${currentUser.role==='admin'?'<button class="btn btn-sm btn-danger" onclick="clearTx()">Hapus Semua</button>':''}
    </div>
    ${filtered.length===0?'<div class="empty-state"><div class="ei">📊</div><p>Belum ada transaksi</p></div>':''}
    <table class="tbl">
      <thead><tr><th>Waktu</th><th>Customer</th><th>Barber</th><th>Total</th><th>Bayar</th></tr></thead>
      <tbody>${[...filtered].reverse().slice(0,50).map(t=>`
      <tr>
        <td style="font-family:monospace;font-size:.68rem">${new Date(t.date).toLocaleString('id-ID',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</td>
        <td>${t.customer}</td>
        <td>${t.barber}</td>
        <td style="color:${t.isHutang?'var(--ember)':'var(--teal)'};font-weight:600">${rp(t.total)}</td>
        <td><span class="badge badge-${t.isHutang?'red':t.payMethod==='qris'?'teal':t.payMethod==='tf'?'gold':'gray'}">${t.isHutang?'Hutang':t.payMethod==='qris'?'QRIS':t.payMethod==='tf'?'TF':'Cash'}</span></td>
      </tr>`).join('')}</tbody>
    </table>
  </div>`;
}

// ══════════════════════════════════════════════
// EXPORT & IMPORT
// ══════════════════════════════════════════════
function getFilteredTx(){
  const txs=DB.get('transactions')||[];
  const now=new Date();
  return txs.filter(tx=>{
    const d=new Date(tx.date);
    if(reportPeriod==='today') return d.toDateString()===now.toDateString();
    if(reportPeriod==='week'){const w=new Date(now);w.setDate(w.getDate()-7);return d>=w;}
    if(reportPeriod==='month') return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
    return true;
  });
}

function exportCSV(){
  const txs=getFilteredTx();
  if(txs.length===0){alert('Tidak ada data untuk diekspor pada periode ini');return;}
  const rows=[['No','Tanggal','Waktu','Customer','Barber','Layanan','Total (Rp)','Komisi (Rp)']];
  txs.forEach((t,i)=>{
    const d=new Date(t.date);
    const items=t.items.map(x=>x.name).join(' + ');
    rows.push([
      i+1,
      d.toLocaleDateString('id-ID'),
      d.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'}),
      t.customer,
      t.barber,
      items,
      t.total,
      t.commission
    ]);
  });
  // Summary row
  const totalSum=txs.reduce((a,t)=>a+t.total,0);
  const commSum=txs.reduce((a,t)=>a+t.commission,0);
  rows.push([]);
  rows.push(['','','','','','TOTAL',totalSum,commSum]);
  rows.push(['','','','','','NET (setelah komisi)',totalSum-commSum,'']);

  const csv=rows.map(r=>r.map(c=>{
    const s=String(c===undefined||c===null?'':c);
    return s.includes(',')||s.includes('"')||s.includes('\n')?'"'+s.replace(/"/g,'""')+'"':s;
  }).join(',')).join('\n');

  const period={today:'hari-ini',week:'minggu-ini',month:'bulan-ini',all:'semua'}[reportPeriod];
  const fname='romebois-laporan-'+period+'-'+new Date().toISOString().split('T')[0]+'.csv';
  downloadFile(csv,'text/csv;charset=utf-8;',fname);
}

function exportJSON(){
  const now=new Date().toISOString().split('T')[0];
  const backup={
    version:1,
    exportedAt:new Date().toISOString(),
    exportedBy:currentUser.name,
    data:{
      transactions:       DB.get('transactions')||[],
      appointments:       DB.get('appointments')||[],
      members:            DB.get('members')||[],
      services:           DB.get('services')||[],
      settings:           DB.get('settings')||{},
      expenses:           DB.get('expenses')||[],
      expense_categories: DB.get('expense_categories')||[],
      addons:             DB.get('addons')||[],
      debts:              DB.get('debts')||[]
    }
  };
  const json=JSON.stringify(backup,null,2);
  downloadFile(json,'application/json','romebois-backup-'+now+'.json');
}

function importJSON(event){
  const file=event.target.files[0];
  if(!file) return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const backup=JSON.parse(e.target.result);
      if(!backup.version||!backup.data) throw new Error('Format file tidak valid');
      const d=backup.data;
      const confirm_msg=
        'Import backup dari '+new Date(backup.exportedAt).toLocaleString('id-ID')+'?\n\n'+
        '⚠️ Data yang ada akan DIGABUNG (bukan dihapus).\n'+
        'Transaksi duplikat akan dilewati.\n\n'+
        'Lanjutkan?';
      if(!confirm(confirm_msg)){event.target.value='';return;}

      let imported=0;
      // Merge transactions (by id)
      if(d.transactions){
        const existing=DB.get('transactions')||[];
        const existIds=new Set(existing.map(x=>x.id));
        const newTx=d.transactions.filter(x=>!existIds.has(x.id));
        DB.set('transactions',[...existing,...newTx]);
        imported+=newTx.length;
      }
      // Merge expenses
      if(d.expenses){
        const existing=DB.get('expenses')||[];
        const existIds=new Set(existing.map(x=>x.id));
        const newEx=d.expenses.filter(x=>!existIds.has(x.id));
        DB.set('expenses',[...existing,...newEx]);
      }
      if(d.expense_categories){
        const existing=DB.get('expense_categories')||[];
        const merged=[...new Set([...existing,...d.expense_categories])];
        DB.set('expense_categories',merged);
      }
      if(d.addons&&confirm('Timpa daftar add-ons & stok dengan data dari backup?')){
        DB.set('addons',d.addons);
      }
      if(d.debts){
        const existing=DB.get('debts')||[];
        const existIds=new Set(existing.map(x=>x.id));
        const newDb=d.debts.filter(x=>!existIds.has(x.id));
        DB.set('debts',[...existing,...newDb]);
      }
      // Merge appointments
      if(d.appointments){
        const existing=DB.get('appointments')||[];
        const existIds=new Set(existing.map(x=>x.id));
        const newAp=d.appointments.filter(x=>!existIds.has(x.id));
        DB.set('appointments',[...existing,...newAp]);
      }
      // Merge members
      if(d.members){
        const existing=DB.get('members')||[];
        const existIds=new Set(existing.map(x=>x.id));
        const newMb=d.members.filter(x=>!existIds.has(x.id));
        DB.set('members',[...existing,...newMb]);
      }
      // Overwrite services & settings only if admin confirms
      if(d.services&&confirm('Timpa daftar layanan & harga dengan data dari backup?')){
        DB.set('services',d.services);
      }
      if(d.settings&&confirm('Timpa pengaturan (komisi, member) dengan data dari backup?')){
        DB.set('settings',d.settings);
      }
      alert('✅ Import berhasil! '+imported+' transaksi baru ditambahkan.');
      renderPanel('laporan');
    } catch(err){
      alert('❌ Gagal import: '+err.message);
    }
    event.target.value='';
  };
  reader.readAsText(file);
}

function downloadFile(content, mimeType, filename){
  const blob=new Blob([content],{type:mimeType});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download=filename;
  document.body.appendChild(a); a.click();
  setTimeout(()=>{document.body.removeChild(a);URL.revokeObjectURL(url);},100);
}

function clearTx(){
  if(!confirm('Hapus SEMUA riwayat transaksi? Ini tidak bisa dibatalkan!')) return;
  DB.set('transactions',[]);
  renderLaporan(document.getElementById('panel-laporan'));
}

// ══════════════════════════════════════════════
// ADMIN
// ══════════════════════════════════════════════
function renderAdmin(el){
  const svcs=DB.get('services')||[];
  const users=DB.get('users')||[];
  const settings=DB.get('settings')||{commission:40,memberVisits:10,memberReward:'1x Potong Gratis'};
  el.innerHTML=`
  <!-- INFO TOKO -->
  <div class="card">
    <div class="card-title">📍 Info Toko</div>
    <div class="field"><label>Nama Toko</label><input class="finp" id="set-shopname" value="${settings.shopName||''}" placeholder="Nama barbershop"></div>
    <div class="field"><label>Alamat</label><input class="finp" id="set-shopaddr" value="${settings.shopAddress||''}" placeholder="Alamat toko"></div>
    <div class="field"><label>No HP / WhatsApp</label><input class="finp" id="set-shopphone" value="${settings.shopPhone||''}" placeholder="08xx-xxxx-xxxx"></div>
    <div class="field"><label>Tagline</label><input class="finp" id="set-shoptagline" value="${settings.shopTagline||''}" placeholder="(opsional)"></div>
    <button class="btn btn-teal" onclick="saveShopInfo()">Simpan Info Toko</button>
  </div>

  <!-- USERS / PIN -->
  <div class="card">
    <div class="card-title">Manajemen Barber & PIN
      <button class="btn btn-teal btn-sm" onclick="openAddUser()">+ Tambah</button>
    </div>
    ${users.map(u=>`
    <div class="pin-user-row">
      <div><strong>${u.name}</strong> <span class="badge badge-${u.role==='admin'?'teal':'gray'}">${u.role==='admin'?'Admin':'Barber'}</span></div>
      <div style="display:flex;gap:.4rem;align-items:center">
        <span style="font-family:monospace;color:var(--ash);font-size:.75rem">PIN: ${u.pin}</span>
        <button class="btn btn-sm btn-outline" onclick="openEditPin('${u.id}')">Ubah PIN</button>
        ${u.id!=='anang'?'<button class="btn btn-sm btn-danger" onclick="deleteUser(\''+u.id+'\')">&#128465;</button>':''}
      </div>
    </div>`).join('')}
  </div>

  <!-- LAYANAN -->
  <div class="card">
    <div class="card-title">Daftar Layanan & Harga
      <button class="btn btn-teal btn-sm" onclick="openAddService()">+ Tambah</button>
    </div>
    <table class="tbl">
      <thead><tr><th>Layanan</th><th>Harga</th><th>Status</th><th></th></tr></thead>
      <tbody>${svcs.map(s=>`
      <tr>
        <td>${s.name}</td>
        <td style="color:var(--teal)">${rp(s.price)}</td>
        <td><span class="badge badge-${s.active?'teal':'gray'}">${s.active?'Aktif':'Nonaktif'}</span></td>
        <td><button class="btn btn-sm btn-outline" onclick="openEditService('${s.id}')">Edit</button></td>
      </tr>`).join('')}</tbody>
    </table>
  </div>

  <!-- ADD-ONS -->
  <div class="card">
    <div class="card-title">Add-ons & Produk Retail
      <button class="btn btn-teal btn-sm" onclick="openAddAddon()">+ Tambah</button>
    </div>
    <table class="tbl">
      <thead><tr><th>Produk</th><th>Harga</th><th>Stok</th><th>Status</th><th></th></tr></thead>
      <tbody>${(DB.get('addons')||[]).map(a=>`
      <tr>
        <td>${a.name}</td>
        <td style="color:var(--teal)">${rp(a.price)}</td>
        <td>
          <div style="display:flex;align-items:center;gap:.4rem">
            <button onclick="adjStock('${a.id}',-1)" style="background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:#fca5a5;border-radius:5px;padding:.1rem .4rem;cursor:pointer;font-size:.8rem">−</button>
            <span style="font-family:monospace;min-width:24px;text-align:center">${a.stock??'∞'}</span>
            <button onclick="adjStock('${a.id}',1)" style="background:rgba(10,191,188,.1);border:1px solid rgba(10,191,188,.2);color:var(--teal);border-radius:5px;padding:.1rem .4rem;cursor:pointer;font-size:.8rem">+</button>
          </div>
        </td>
        <td><span class="badge badge-${a.active?'teal':'gray'}">${a.active?'Aktif':'Nonaktif'}</span></td>
        <td><button class="btn btn-sm btn-outline" onclick="openEditAddon('${a.id}')">Edit</button></td>
      </tr>`).join('')}</tbody>
    </table>
  </div>

  <!-- SETTINGS -->
  <div class="card">
    <div class="card-title">Pengaturan Umum</div>
    <div class="field"><label>Komisi Barber (%)</label>
      <input class="finp" type="number" id="set-comm" value="${settings.commission}" min="0" max="100">
    </div>
    <div class="field"><label>Target Kunjungan Member</label>
      <input class="finp" type="number" id="set-mvisit" value="${settings.memberVisits}" min="1">
    </div>
    <div class="field"><label>Reward Member</label>
      <input class="finp" id="set-mreward" value="${settings.memberReward}" placeholder="contoh: 1x Potong Gratis">
    </div>
    <div class="field"><label>Estimasi Waktu per Antrian (menit)</label>
      <input class="finp" type="number" id="set-qest" value="${settings.queueEstimate||20}" min="5" max="120">
    </div>
    <button class="btn btn-teal" onclick="saveSettings()">Simpan Pengaturan</button>
  </div>

  <!-- TENTANG -->
  <div class="card">
    <div class="card-title">ℹ️ Tentang</div>
    <div style="text-align:center;padding:.5rem 0">
      <div style="font-size:1.2rem;font-weight:800;color:var(--teal)">💈 Pangkas v1.0</div>
      <div style="font-size:.75rem;color:var(--ash);margin-top:.3rem">Aplikasi manajemen barbershop</div>
      <div style="font-size:.68rem;color:var(--ash);margin-top:.5rem">Made with 💈 by <a href="https://github.com/Icattj" target="_blank" style="color:var(--teal);text-decoration:none">Sentra Technology</a></div>
    </div>
  </div>`;
}

function openAddUser(){
  openModal(`<h3>👤 Tambah Barber</h3>
    <div class="field"><label>Nama</label><input class="finp" id="u-name" placeholder="Nama barber"></div>
    <div class="field"><label>PIN (4 digit)</label><input class="finp" id="u-pin" type="number" maxlength="4" placeholder="contoh: 5678"></div>
    <div class="field"><label>Role</label><select class="finp" id="u-role"><option value="barber">Barber</option><option value="admin">Admin</option></select></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveUser()">Simpan</button>
    </div>`);
}

function saveUser(){
  const name=document.getElementById('u-name')?.value?.trim();
  const pin=String(document.getElementById('u-pin')?.value||'').trim();
  const role=document.getElementById('u-role')?.value;
  if(!name||pin.length!==4){alert('Nama dan PIN 4 digit wajib diisi');return;}
  const users=DB.get('users')||[];
  if(users.some(u=>u.pin===pin)){alert('PIN sudah digunakan, pilih PIN lain');return;}
  users.push({id:'u-'+Date.now(),name,pin,role});
  DB.set('users',users);
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function openEditPin(id){
  openModal(`<h3>🔑 Ubah PIN</h3>
    <div class="field"><label>PIN Baru (4 digit)</label><input class="finp" id="np-pin" type="number" maxlength="4" placeholder="PIN baru"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="savePin('${id}')">Simpan</button>
    </div>`);
}

function savePin(id){
  const pin=String(document.getElementById('np-pin')?.value||'').trim();
  if(pin.length!==4){alert('PIN harus 4 digit');return;}
  const users=DB.get('users')||[];
  if(users.some(u=>u.pin===pin&&u.id!==id)){alert('PIN sudah digunakan');return;}
  const u=users.find(x=>x.id===id);
  if(u) u.pin=pin;
  DB.set('users',users);
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function deleteUser(id){
  if(!confirm('Hapus barber ini?')) return;
  DB.set('users',(DB.get('users')||[]).filter(u=>u.id!==id));
  renderAdmin(document.getElementById('panel-admin'));
}

function openAddService(){
  openModal(`<h3>✂️ Tambah Layanan</h3>
    <div class="field"><label>Nama Layanan</label><input class="finp" id="sv-name" placeholder="contoh: Potong Rambut"></div>
    <div class="field"><label>Harga (Rp)</label><input class="finp" type="number" id="sv-price" placeholder="35000"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveService(null)">Simpan</button>
    </div>`);
}

function openEditService(id){
  const svcs=DB.get('services')||[];
  const s=svcs.find(x=>x.id===id);
  if(!s) return;
  openModal(`<h3>✂️ Edit Layanan</h3>
    <div class="field"><label>Nama Layanan</label><input class="finp" id="sv-name" value="${s.name}"></div>
    <div class="field"><label>Harga (Rp)</label><input class="finp" type="number" id="sv-price" value="${s.price}"></div>
    <div class="field"><label>Status</label><select class="finp" id="sv-active"><option value="true" ${s.active?'selected':''}>Aktif</option><option value="false" ${!s.active?'selected':''}>Nonaktif</option></select></div>
    <div class="modal-footer">
      <button class="btn btn-danger btn-sm" onclick="deleteService('${id}')">Hapus</button>
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveService('${id}')">Simpan</button>
    </div>`);
}

function saveService(id){
  const name=document.getElementById('sv-name')?.value?.trim();
  const price=parseInt(document.getElementById('sv-price')?.value)||0;
  const active=document.getElementById('sv-active')?.value!=='false';
  if(!name||!price){alert('Nama dan harga wajib diisi');return;}
  const svcs=DB.get('services')||[];
  if(id){
    const s=svcs.find(x=>x.id===id);
    if(s){s.name=name;s.price=price;s.active=active;}
  } else {
    svcs.push({id:'s-'+Date.now(),name,price,active:true});
  }
  DB.set('services',svcs);
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function deleteService(id){
  if(!confirm('Hapus layanan ini?')) return;
  DB.set('services',(DB.get('services')||[]).filter(s=>s.id!==id));
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function saveShopInfo(){
  const s=DB.get('settings')||{};
  s.shopName=document.getElementById('set-shopname')?.value?.trim()||'';
  s.shopAddress=document.getElementById('set-shopaddr')?.value?.trim()||'';
  s.shopPhone=document.getElementById('set-shopphone')?.value?.trim()||'';
  s.shopTagline=document.getElementById('set-shoptagline')?.value?.trim()||'';
  DB.set('settings',s);
  updateLoginBrand();
  alert('Info toko disimpan!');
}

function saveSettings(){
  const s=DB.get('settings')||{};
  s.commission=parseInt(document.getElementById('set-comm')?.value)||40;
  s.memberVisits=parseInt(document.getElementById('set-mvisit')?.value)||10;
  s.memberReward=document.getElementById('set-mreward')?.value||'1x Potong Gratis';
  s.queueEstimate=parseInt(document.getElementById('set-qest')?.value)||20;
  DB.set('settings',s);
  alert('Pengaturan disimpan!');
}

// ══════════════════════════════════════════════
// HUTANG TRACKER
// ══════════════════════════════════════════════
function renderHutang(el){
  const debts=DB.get('debts')||[];
  const unpaid=debts.filter(d=>!d.paid);
  const paid=debts.filter(d=>d.paid);
  const totalUnpaid=unpaid.reduce((a,d)=>a+d.amount,0);

  el.innerHTML=`
  <div class="grid2" style="margin-bottom:.75rem">
    <div class="stat-card">
      <div class="stat-val" style="color:var(--ember)">${unpaid.length}</div>
      <div class="stat-lbl">Hutang Belum Lunas</div>
    </div>
    <div class="stat-card">
      <div class="stat-val" style="font-size:1.1rem;color:var(--ember)">${rp(totalUnpaid)}</div>
      <div class="stat-lbl">Total Piutang</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title" style="color:var(--ember)">⚠️ Belum Lunas (${unpaid.length})</div>
    ${unpaid.length===0?'<div class="empty-state"><div class="ei">✅</div><p>Tidak ada hutang!</p></div>':''}
    ${[...unpaid].sort((a,b)=>new Date(a.date)-new Date(b.date)).map(d=>`
    <div class="debt-card">
      <div style="display:flex;justify-content:space-between;align-items:flex-start">
        <div>
          <div class="debt-name">👤 ${d.customer}</div>
          <div class="debt-amount">${rp(d.amount)}</div>
          <div class="debt-meta">✂️ ${d.barber} · ${new Date(d.date).toLocaleDateString('id-ID',{day:'numeric',month:'short',year:'numeric'})}</div>
          ${d.note?`<div class="debt-meta" style="color:var(--ivory);margin-top:.2rem">📝 ${d.note}</div>`:''}
        </div>
        <div style="display:flex;flex-direction:column;gap:.3rem;align-items:flex-end">
          <button class="btn btn-sm btn-teal" onclick="markDebtPaid('${d.id}')">✅ Lunas</button>
          ${currentUser.role==='admin'?'<button class="btn btn-sm btn-danger" onclick="deleteDebt(\''+d.id+'\')">&#128465;</button>':''}
        </div>
      </div>
    </div>`).join('')}
  </div>

  ${paid.length>0?`
  <div class="card">
    <div class="card-title" style="color:var(--sage)">✅ Sudah Lunas (${paid.length})</div>
    ${[...paid].reverse().slice(0,20).map(d=>`
    <div class="debt-card paid">
      <div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <div class="debt-name">👤 ${d.customer}</div>
          <div class="debt-amount paid">${rp(d.amount)}</div>
          <div class="debt-meta">Lunas: ${new Date(d.paidAt).toLocaleDateString('id-ID',{day:'numeric',month:'short'})}</div>
        </div>
        ${currentUser.role==='admin'?'<button class="btn btn-sm btn-danger" onclick="deleteDebt(\''+d.id+'\')">&#128465;</button>':''}
      </div>
    </div>`).join('')}
  </div>`:''}`;
}

function markDebtPaid(id){
  if(!confirm('Tandai hutang ini sebagai LUNAS?')) return;
  const debts=DB.get('debts')||[];
  const d=debts.find(x=>x.id===id);
  if(d){ d.paid=true; d.paidAt=new Date().toISOString(); }
  // Update transaction commission now that it's paid
  if(d){
    const txs=DB.get('transactions')||[];
    const tx=txs.find(t=>t.id===d.txId);
    if(tx){
      const settings=DB.get('settings')||{commission:40};
      tx.commission=Math.round(tx.total*settings.commission/100);
      tx.isHutang=false;
      DB.set('transactions',txs);
    }
  }
  DB.set('debts',debts);
  renderHutang(document.getElementById('panel-hutang'));
}

function deleteDebt(id){
  if(!confirm('Hapus catatan hutang ini?')) return;
  DB.set('debts',(DB.get('debts')||[]).filter(d=>d.id!==id));
  renderHutang(document.getElementById('panel-hutang'));
}

// ══════════════════════════════════════════════
// BELANJA / PENGELUARAN
// ══════════════════════════════════════════════
function renderBelanja(el){
  const expenses=DB.get('expenses')||[];
  const cats=DB.get('expense_categories')||[];
  const now=new Date();
  // Filter this month by default
  const thisMonth=expenses.filter(e=>{
    const d=new Date(e.date);
    return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();
  });
  const totalMonth=thisMonth.reduce((a,e)=>a+e.amount,0);
  const totalAll=expenses.reduce((a,e)=>a+e.amount,0);
  // Group by category
  const byCat={};
  thisMonth.forEach(e=>{ byCat[e.category]=(byCat[e.category]||0)+e.amount; });

  el.innerHTML=`
  <div class="grid2" style="margin-bottom:.75rem">
    <div class="stat-card">
      <div class="stat-val" style="font-size:1.1rem;color:var(--ember)">${rp(totalMonth)}</div>
      <div class="stat-lbl">Pengeluaran Bulan Ini</div>
    </div>
    <div class="stat-card">
      <div class="stat-val" style="font-size:1.1rem;color:var(--ember)">${rp(totalAll)}</div>
      <div class="stat-lbl">Total Semua Pengeluaran</div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">Per Kategori (Bulan Ini)</div>
    ${Object.keys(byCat).length===0?'<div style="color:var(--ash);font-size:.78rem;padding:.3rem 0">Belum ada pengeluaran bulan ini</div>':
    Object.entries(byCat).sort((a,b)=>b[1]-a[1]).map(([cat,amt])=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:.78rem">
      <span>📦 ${cat}</span>
      <span style="color:var(--ember);font-weight:700">${rp(amt)}</span>
    </div>`).join('')}
  </div>

  <div class="card">
    <div class="card-title">Riwayat Belanja
      <button class="btn btn-teal btn-sm" onclick="openAddBelanja()">+ Tambah</button>
    </div>
    ${expenses.length===0?'<div class="empty-state"><div class="ei">🛒</div><p>Belum ada catatan pengeluaran</p></div>':''}
    <table class="tbl">
      <thead><tr><th>Tanggal</th><th>Nama</th><th>Kategori</th><th>Jumlah</th><th></th></tr></thead>
      <tbody id="expenseRows">${renderExpenseRows(expenses)}</tbody>
    </table>
  </div>`;
}

function renderExpenseRows(expenses){
  if(expenses.length===0) return '';
  return [...expenses].sort((a,b)=>new Date(b.date)-new Date(a.date)).slice(0,100).map(function(e){
    const addons=DB.get('addons')||[];
    const linkedAddon=e.addonId?addons.find(a=>a.id===e.addonId):null;
    const qtyLabel=e.qty&&e.qty>1?' ('+e.qty+' pcs @ '+rp(e.unitPrice||0)+')':'';
    const profitHtml=linkedAddon&&e.unitPrice?
      ' <span style="font-size:.62rem;color:var(--sage)">jual '+rp(linkedAddon.price)+' → profit '+rp(linkedAddon.price-(e.unitPrice||0))+'/pcs</span>':'';
    const addonBadge=linkedAddon?'<br><span class="badge badge-teal" style="margin-top:2px">🧴 '+linkedAddon.name+'</span>':'';
    return '<tr>'+
      '<td style="font-size:.7rem;font-family:monospace">'+new Date(e.date).toLocaleDateString('id-ID',{day:'numeric',month:'short'})+'</td>'+
      '<td>'+e.name+qtyLabel+(e.note?'<br><span style="font-size:.62rem;color:var(--ash)">'+e.note+'</span>':'')+addonBadge+profitHtml+'</td>'+
      '<td><span class="badge badge-gray">'+e.category+'</span></td>'+
      '<td style="color:var(--ember);font-weight:600">'+rp(e.amount)+'</td>'+
      '<td style="white-space:nowrap">'+
        '<button onclick="openEditExpense(&#39;'+e.id+'&#39;)" style="background:none;border:1px solid rgba(255,255,255,.1);border-radius:6px;color:var(--ash);cursor:pointer;font-size:.68rem;padding:.15rem .4rem;margin-right:.2rem">Edit</button>'+
        '<button onclick="deleteExpense(&#39;'+e.id+'&#39;)" style="background:none;border:none;color:var(--ember);cursor:pointer;font-size:.9rem">&#128465;</button>'+
      '</td>'+
    '</tr>';
  }).join('');
}

function openAddBelanja(){
  const cats=DB.get('expense_categories')||[];
  const addons=DB.get('addons')||[];
  const today=new Date().toISOString().split('T')[0];
  const box=document.getElementById('modalBox');
  box.innerHTML='';

  const h3=document.createElement('h3'); h3.textContent='🛒 Catat Pengeluaran'; box.appendChild(h3);

  // Nama
  const f1=document.createElement('div'); f1.className='field';
  f1.innerHTML='<label>Nama Item / Keperluan</label><input class="finp" id="ex-name" placeholder="contoh: Pomade Gatsby">';
  box.appendChild(f1);

  // Kategori
  const f2=document.createElement('div'); f2.className='field';
  const catOpts=cats.map(c=>'<option value="'+c+'">'+c+'</option>').join('')+'<option value="__new__">+ Kategori baru...</option>';
  f2.innerHTML='<label>Kategori</label><select class="finp" id="ex-cat">'+catOpts+'</select>';
  box.appendChild(f2);

  // New cat field (hidden)
  const f2b=document.createElement('div'); f2b.className='field'; f2b.id='newCatField'; f2b.style.display='none';
  f2b.innerHTML='<label>Nama Kategori Baru</label><input class="finp" id="ex-newcat" placeholder="Nama kategori">';
  box.appendChild(f2b);

  // Quantity + Unit price row
  const fqrow=document.createElement('div');
  fqrow.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:.5rem';
  fqrow.innerHTML=
    '<div class="field"><label>Jumlah / Qty</label><input class="finp" type="number" id="ex-qty" placeholder="1" value="1" min="1"></div>'+
    '<div class="field"><label>Harga Satuan (Rp)</label><input class="finp" type="number" id="ex-unitprice" placeholder="15000"></div>';
  box.appendChild(fqrow);

  // Total amount (auto-calc, readonly)
  const ftotal=document.createElement('div'); ftotal.className='field';
  ftotal.innerHTML='<label>Total Pengeluaran (Rp) <span style="color:var(--ash);font-weight:400">(otomatis)</span></label>'+
    '<input class="finp" type="number" id="ex-amount" placeholder="0" style="background:rgba(10,191,188,.05);border-color:rgba(10,191,188,.2)">';
  box.appendChild(ftotal);

  // Auto-calc total
  setTimeout(()=>{
    const qtyEl=document.getElementById('ex-qty');
    const priceEl=document.getElementById('ex-unitprice');
    const totalEl=document.getElementById('ex-amount');
    function calcTotal(){
      const q=parseInt(qtyEl.value)||1;
      const p=parseInt(priceEl.value)||0;
      totalEl.value=q*p||'';
    }
    qtyEl.addEventListener('input',calcTotal);
    priceEl.addEventListener('input',calcTotal);
    document.getElementById('ex-cat')?.addEventListener('change',function(){
      document.getElementById('newCatField').style.display=this.value==='__new__'?'block':'none';
    });
  },100);

  // Tanggal
  const fdate=document.createElement('div'); fdate.className='field';
  fdate.innerHTML='<label>Tanggal</label><input class="finp" type="date" id="ex-date" value="'+today+'">';
  box.appendChild(fdate);

  // Catatan
  const fnote=document.createElement('div'); fnote.className='field';
  fnote.innerHTML='<label>Catatan (opsional)</label><input class="finp" id="ex-note" placeholder="Catatan tambahan">';
  box.appendChild(fnote);

  // Add to Add-ons — chip checklist
  const ftoggle=document.createElement('div');
  ftoggle.style.cssText='background:rgba(10,191,188,.06);border:1px solid rgba(10,191,188,.2);border-radius:10px;padding:.7rem .85rem;margin-bottom:.75rem';
  const chipItems=[{id:'',label:'Tidak / Skip'}].concat(addons.map(a=>({id:a.id,label:a.name}))).concat([{id:'__new__',label:'+ Buat add-on baru'}]);
  const chipsHtml=chipItems.map(function(c){
    return '<div class="addon-chip" data-id="'+c.id+'" onclick="selectAddonChip(this)" style="display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .7rem;border:1px solid rgba(255,255,255,.1);border-radius:20px;background:rgba(255,255,255,.03);cursor:pointer;font-size:.75rem;margin:.2rem;transition:all .18s">'+
      '<span class="chip-dot" style="width:8px;height:8px;border-radius:50%;border:2px solid rgba(10,191,188,.4);flex-shrink:0"></span>'+
      '<span>'+c.label+'</span>'+
    '</div>';
  }).join('');
  ftoggle.innerHTML=
    '<label style="font-size:.72rem;font-weight:700;color:var(--teal);display:block;margin-bottom:.5rem">🧴 Tambah ke Stok Add-ons?</label>'+
    '<div id="addonChips" style="display:flex;flex-wrap:wrap;gap:.1rem;margin-bottom:.4rem">'+chipsHtml+'</div>'+
    '<input type="hidden" id="ex-addon" value="">'+
    '<div id="ex-addon-newname" style="display:none;margin-top:.4rem">'+
      '<input class="finp" id="ex-addon-name" placeholder="Nama add-on baru" style="margin-bottom:.3rem">'+
      '<input class="finp" type="number" id="ex-addon-sellprice" placeholder="Harga jual (Rp)">'+
    '</div>'+
    '<div id="ex-profit-preview" style="font-size:.72rem;margin-top:.4rem;padding:.35rem .5rem;border-radius:7px;display:none"></div>';
  box.appendChild(ftoggle);

  // Select first chip by default
  setTimeout(()=>{
    const firstChip=document.querySelector('.addon-chip');
    if(firstChip) selectAddonChip(firstChip);

    function updateProfit(){
      const addonSel=document.getElementById('ex-addon')?.value||'';
      const qty=parseInt(document.getElementById('ex-qty')?.value)||1;
      const unitPrice=parseInt(document.getElementById('ex-unitprice')?.value)||0;
      const preview=document.getElementById('ex-profit-preview');
      document.getElementById('ex-addon-newname').style.display=addonSel==='__new__'?'block':'none';
      if(addonSel&&addonSel!=='__new__'&&addonSel!==''){
        const a=(DB.get('addons')||[]).find(x=>x.id===addonSel);
        if(a&&unitPrice>0){
          const profitPer=a.price-unitPrice;
          const profitTotal=profitPer*qty;
          preview.style.display='block';
          preview.style.background=profitPer>=0?'rgba(16,185,129,.08)':'rgba(239,68,68,.08)';
          preview.style.color=profitPer>=0?'var(--sage)':'var(--ember)';
          preview.style.border='1px solid '+(profitPer>=0?'rgba(16,185,129,.2)':'rgba(239,68,68,.2)');
          preview.textContent='Profit '+rp(profitPer)+'/pcs · Total '+rp(profitTotal)+' ('+qty+' pcs × jual '+rp(a.price)+')';
        } else { preview.style.display='none'; }
      } else { preview.style.display='none'; }
    }
    document.getElementById('ex-qty')?.addEventListener('input',updateProfit);
    document.getElementById('ex-unitprice')?.addEventListener('input',updateProfit);
    // Watch hidden input change
    const obs=new MutationObserver(updateProfit);
    const hiddenEl=document.getElementById('ex-addon');
    if(hiddenEl) obs.observe(hiddenEl,{attributes:true});
  },150);

  // Footer
  const footer=document.createElement('div'); footer.className='modal-footer';
  const cancelBtn=document.createElement('button'); cancelBtn.className='btn btn-outline'; cancelBtn.textContent='Batal'; cancelBtn.onclick=closeModal;
  const saveBtn=document.createElement('button'); saveBtn.className='btn btn-teal'; saveBtn.textContent='Simpan'; saveBtn.onclick=saveExpense;
  footer.appendChild(cancelBtn); footer.appendChild(saveBtn);
  box.appendChild(footer);

  document.getElementById('modalOverlay').classList.add('open');
}

function openEditExpense(id){
  const expenses=DB.get('expenses')||[];
  const e=expenses.find(x=>x.id===id);
  if(!e) return;
  const cats=DB.get('expense_categories')||[];
  const addons=DB.get('addons')||[];
  const box=document.getElementById('modalBox');
  box.innerHTML='';

  const h3=document.createElement('h3'); h3.textContent='✏️ Edit Pengeluaran'; box.appendChild(h3);

  // Nama
  const f1=document.createElement('div'); f1.className='field';
  f1.innerHTML='<label>Nama Item</label><input class="finp" id="ee-name" value="'+e.name+'">';
  box.appendChild(f1);

  // Kategori
  const f2=document.createElement('div'); f2.className='field';
  const catOpts=cats.map(c=>'<option value="'+c+'"'+(c===e.category?' selected':'')+'>'+c+'</option>').join('');
  f2.innerHTML='<label>Kategori</label><select class="finp" id="ee-cat">'+catOpts+'</select>';
  box.appendChild(f2);

  // Qty + Unit price
  const fqrow=document.createElement('div');
  fqrow.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:.5rem';
  fqrow.innerHTML=
    '<div class="field"><label>Qty</label><input class="finp" type="number" id="ee-qty" value="'+(e.qty||1)+'" min="1"></div>'+
    '<div class="field"><label>Harga Satuan (Rp)</label><input class="finp" type="number" id="ee-unitprice" value="'+(e.unitPrice||e.amount)+'" ></div>';
  box.appendChild(fqrow);

  // Total (auto)
  const ftotal=document.createElement('div'); ftotal.className='field';
  ftotal.innerHTML='<label>Total (Rp)</label><input class="finp" type="number" id="ee-amount" value="'+e.amount+'" style="background:rgba(10,191,188,.05);border-color:rgba(10,191,188,.2)">';
  box.appendChild(ftotal);

  setTimeout(()=>{
    const qEl=document.getElementById('ee-qty');
    const pEl=document.getElementById('ee-unitprice');
    const tEl=document.getElementById('ee-amount');
    function calc(){ const q=parseInt(qEl.value)||1; const p=parseInt(pEl.value)||0; if(p) tEl.value=q*p; }
    qEl.addEventListener('input',calc); pEl.addEventListener('input',calc);
  },100);

  // Tanggal
  const fdate=document.createElement('div'); fdate.className='field';
  fdate.innerHTML='<label>Tanggal</label><input class="finp" type="date" id="ee-date" value="'+e.date+'">';
  box.appendChild(fdate);

  // Catatan
  const fnote=document.createElement('div'); fnote.className='field';
  fnote.innerHTML='<label>Catatan</label><input class="finp" id="ee-note" value="'+(e.note||'')+'">';
  box.appendChild(fnote);

  // Footer
  const footer=document.createElement('div'); footer.className='modal-footer';
  const delBtn=document.createElement('button'); delBtn.className='btn btn-danger btn-sm'; delBtn.textContent='Hapus';
  delBtn.onclick=function(){ closeModal(); deleteExpense(id); };
  const cancelBtn=document.createElement('button'); cancelBtn.className='btn btn-outline'; cancelBtn.textContent='Batal'; cancelBtn.onclick=closeModal;
  const saveBtn=document.createElement('button'); saveBtn.className='btn btn-teal'; saveBtn.textContent='Simpan';
  saveBtn.onclick=function(){
    const name=document.getElementById('ee-name')?.value?.trim();
    const cat=document.getElementById('ee-cat')?.value;
    const qty=parseInt(document.getElementById('ee-qty')?.value)||1;
    const unitPrice=parseInt(document.getElementById('ee-unitprice')?.value)||0;
    const amount=parseInt(document.getElementById('ee-amount')?.value)||unitPrice*qty;
    const date=document.getElementById('ee-date')?.value;
    const note=document.getElementById('ee-note')?.value?.trim();
    if(!name||!amount||!date){alert('Nama, jumlah, dan tanggal wajib diisi');return;}
    const exps=DB.get('expenses')||[];
    const ex=exps.find(x=>x.id===id);
    if(ex){ ex.name=name; ex.category=cat; ex.qty=qty; ex.unitPrice=unitPrice; ex.amount=amount; ex.date=date; ex.note=note; }
    DB.set('expenses',exps);
    closeModal();
    renderBelanja(document.getElementById('panel-belanja'));
  };
  footer.appendChild(delBtn); footer.appendChild(cancelBtn); footer.appendChild(saveBtn);
  box.appendChild(footer);
  document.getElementById('modalOverlay').classList.add('open');
}

function selectAddonChip(el){
  // Deselect all
  document.querySelectorAll('.addon-chip').forEach(function(c){
    c.style.background='rgba(255,255,255,.03)';
    c.style.borderColor='rgba(255,255,255,.1)';
    c.style.color='';
    c.querySelector('.chip-dot').style.background='transparent';
    c.querySelector('.chip-dot').style.borderColor='rgba(10,191,188,.4)';
  });
  // Select this
  el.style.background='rgba(10,191,188,.12)';
  el.style.borderColor='rgba(10,191,188,.5)';
  el.querySelector('.chip-dot').style.background='var(--teal)';
  el.querySelector('.chip-dot').style.borderColor='var(--teal)';
  // Set hidden input
  const id=el.getAttribute('data-id')||'';
  const hiddenEl=document.getElementById('ex-addon');
  if(hiddenEl){
    hiddenEl.value=id;
    hiddenEl.dispatchEvent(new Event('change'));
  }
  // Show/hide new addon fields
  const newDiv=document.getElementById('ex-addon-newname');
  if(newDiv) newDiv.style.display=id==='__new__'?'block':'none';
  // Trigger profit update
  const qty=parseInt(document.getElementById('ex-qty')?.value)||1;
  const unitPrice=parseInt(document.getElementById('ex-unitprice')?.value)||0;
  const preview=document.getElementById('ex-profit-preview');
  if(id&&id!=='__new__'&&id!==''){
    const a=(DB.get('addons')||[]).find(x=>x.id===id);
    if(a&&unitPrice>0&&preview){
      const profitPer=a.price-unitPrice;
      const profitTotal=profitPer*qty;
      preview.style.display='block';
      preview.style.background=profitPer>=0?'rgba(16,185,129,.08)':'rgba(239,68,68,.08)';
      preview.style.color=profitPer>=0?'var(--sage)':'var(--ember)';
      preview.style.border='1px solid '+(profitPer>=0?'rgba(16,185,129,.2)':'rgba(239,68,68,.2)');
      preview.textContent='Profit '+rp(profitPer)+'/pcs · Total '+rp(profitTotal)+' ('+qty+' pcs × jual '+rp(a.price)+')';
    } else if(preview) preview.style.display='none';
  } else if(preview) preview.style.display='none';
}

function saveExpense(){
  const name=document.getElementById('ex-name')?.value?.trim();
  let cat=document.getElementById('ex-cat')?.value;
  const qty=parseInt(document.getElementById('ex-qty')?.value)||1;
  const unitPrice=parseInt(document.getElementById('ex-unitprice')?.value)||0;
  const amount=parseInt(document.getElementById('ex-amount')?.value)||unitPrice*qty||0;
  const date=document.getElementById('ex-date')?.value;
  const note=document.getElementById('ex-note')?.value?.trim();
  const addonSel=document.getElementById('ex-addon')?.value||'';
  if(!name||!amount||!date){alert('Nama, jumlah, dan tanggal wajib diisi');return;}
  // Handle new category
  if(cat==='__new__'){
    const newCat=document.getElementById('ex-newcat')?.value?.trim();
    if(!newCat){alert('Masukkan nama kategori baru');return;}
    cat=newCat;
    const cats=DB.get('expense_categories')||[];
    if(!cats.includes(cat)){cats.push(cat);DB.set('expense_categories',cats);}
  }
  const expenses=DB.get('expenses')||[];
  expenses.push({
    id:'ex-'+Date.now(),name,category:cat,
    amount,qty,unitPrice,
    date,note,
    addonId:addonSel&&addonSel!=='__new__'?addonSel:null,
    createdAt:new Date().toISOString()
  });
  DB.set('expenses',expenses);
  // Handle add-on stock update
  if(addonSel&&addonSel!=='__new__'&&addonSel!==''){
    // Add qty to existing addon stock
    const addons=DB.get('addons')||[];
    const a=addons.find(x=>x.id===addonSel);
    if(a){ a.stock=(a.stock||0)+qty; DB.set('addons',addons); }
  } else if(addonSel==='__new__'){
    // Create new addon
    const newName=document.getElementById('ex-addon-name')?.value?.trim()||name;
    const sellPrice=parseInt(document.getElementById('ex-addon-sellprice')?.value)||0;
    if(newName&&sellPrice){
      const addons=DB.get('addons')||[];
      addons.push({id:'a-'+Date.now(),name:newName,price:sellPrice,stock:qty,active:true,hpp:unitPrice});
      DB.set('addons',addons);
    }
  }
  closeModal();
  renderBelanja(document.getElementById('panel-belanja'));
}

function deleteExpense(id){
  if(!confirm('Hapus catatan pengeluaran ini?')) return;
  DB.set('expenses',(DB.get('expenses')||[]).filter(e=>e.id!==id));
  renderBelanja(document.getElementById('panel-belanja'));
}

// ══════════════════════════════════════════════
// ADD-ONS CRUD
// ══════════════════════════════════════════════
function openAddAddon(){
  openModal(`<h3>🧴 Tambah Produk Add-on</h3>
    <div class="field"><label>Nama Produk</label><input class="finp" id="ao-name" placeholder="contoh: Pomade Gatsby"></div>
    <div class="field"><label>Harga Jual (Rp)</label><input class="finp" type="number" id="ao-price" placeholder="45000"></div>
    <div class="field"><label>Stok Awal</label><input class="finp" type="number" id="ao-stock" placeholder="10" value="0"></div>
    <div class="modal-footer">
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveAddon(null)">Simpan</button>
    </div>`);
}

function openEditAddon(id){
  const addons=DB.get('addons')||[];
  const a=addons.find(x=>x.id===id);
  if(!a) return;
  openModal(`<h3>🧴 Edit Produk</h3>
    <div class="field"><label>Nama Produk</label><input class="finp" id="ao-name" value="${a.name}"></div>
    <div class="field"><label>Harga Jual (Rp)</label><input class="finp" type="number" id="ao-price" value="${a.price}"></div>
    <div class="field"><label>Stok</label><input class="finp" type="number" id="ao-stock" value="${a.stock||0}"></div>
    <div class="field"><label>Status</label><select class="finp" id="ao-active"><option value="true" ${a.active?'selected':''}>Aktif</option><option value="false" ${!a.active?'selected':''}>Nonaktif</option></select></div>
    <div class="modal-footer">
      <button class="btn btn-danger btn-sm" onclick="deleteAddon('${id}')">Hapus</button>
      <button class="btn btn-outline" onclick="closeModal()">Batal</button>
      <button class="btn btn-teal" onclick="saveAddon('${id}')">Simpan</button>
    </div>`);
}

function saveAddon(id){
  const name=document.getElementById('ao-name')?.value?.trim();
  const price=parseInt(document.getElementById('ao-price')?.value)||0;
  const stock=parseInt(document.getElementById('ao-stock')?.value)||0;
  const active=document.getElementById('ao-active')?.value!=='false';
  if(!name||!price){alert('Nama dan harga wajib diisi');return;}
  const addons=DB.get('addons')||[];
  if(id){
    const a=addons.find(x=>x.id===id);
    if(a){a.name=name;a.price=price;a.stock=stock;a.active=active;}
  } else {
    addons.push({id:'a-'+Date.now(),name,price,stock,active:true});
  }
  DB.set('addons',addons);
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function deleteAddon(id){
  if(!confirm('Hapus produk ini?')) return;
  DB.set('addons',(DB.get('addons')||[]).filter(a=>a.id!==id));
  closeModal();
  renderAdmin(document.getElementById('panel-admin'));
}

function adjStock(id, delta){
  const addons=DB.get('addons')||[];
  const a=addons.find(x=>x.id===id);
  if(a){ a.stock=Math.max(0,(a.stock||0)+delta); DB.set('addons',addons); }
  renderAdmin(document.getElementById('panel-admin'));
}

// ══════════════════════════════════════════════
// MODAL
// ══════════════════════════════════════════════
function openModal(html){
  document.getElementById('modalBox').innerHTML=html;
  document.getElementById('modalOverlay').classList.add('open');
}
function closeModal(){
  document.getElementById('modalOverlay').classList.remove('open');
}

// ══════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════
function rp(n){return 'Rp '+n.toLocaleString('id-ID');}
</script>
</body>
</html>
